<%- include('../partials/header', { title: 'Chat' }) %>
<style>
  .chat-page {
    padding-top: 0px;
    height: 100vh;
    display: flex;
    flex-direction: column;
    background: var(--bg);
  }

  /* ══════════════════════════════
     CHAT HEADER
  ══════════════════════════════ */
  .chat-header {
    background: var(--surface);
    border-bottom: 1.5px solid var(--border);
    flex-shrink: 0;
    box-shadow: var(--shadow-sm);
  }

  .chat-header-main {
    padding: 13px 24px;
    display: flex;
    align-items: center;
    gap: 13px;
  }

  .chat-back {
    width: 36px; height: 36px; border-radius: 50%;
    border: 1.5px solid var(--border);
    display: flex; align-items: center; justify-content: center;
    color: var(--muted); text-decoration: none;
    transition: all .2s; flex-shrink: 0;
  }
  .chat-back:hover { border-color: var(--brand); color: var(--brand); }

  .chat-header-avatar {
    width: 40px; height: 40px; border-radius: 50%;
    object-fit: cover; border: 2px solid var(--brand); flex-shrink: 0;
  }
  .chat-header-avatar-fb {
    width: 40px; height: 40px; border-radius: 50%;
    background: linear-gradient(135deg, var(--brand), var(--brand-2));
    color: #fff; font-size: 15px; font-weight: 700;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }

  .chat-header-info h3 {
    font-family: var(--font-display);
    font-size: 14px; font-weight: 700; color: var(--text);
  }
  .chat-header-info p { font-size: 11px; color: var(--muted); margin-top: 1px; }

  .chat-header-actions {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .chat-header-badge {
    background: rgba(16,185,129,.1); color: #059669;
    font-size: 11px; font-weight: 700;
    padding: 4px 10px; border-radius: 50px;
    display: flex; align-items: center; gap: 4px;
  }

  .btn-schedule {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 7px 14px; border-radius: 50px;
    font-size: 12px; font-weight: 700;
    background: var(--brand-glow); color: var(--brand);
    border: 1.5px solid rgba(124,58,237,.2);
    text-decoration: none;
    transition: all .2s;
    white-space: nowrap;
  }
  .btn-schedule:hover {
    background: var(--brand); color: #fff;
    box-shadow: 0 4px 14px rgba(124,58,237,.3);
  }
  .btn-schedule svg { width: 13px; height: 13px; }

  .chat-header-actions { display: flex; align-items: center; gap: 8px; }
  .complete-form { margin: 0; }
  .btn-complete {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 7px 14px; border-radius: 8px;
    background: #dbeafe; color: #1d4ed8;
    border: 1.5px solid #bfdbfe;
    font-size: 12px; font-weight: 700; font-family: inherit;
    cursor: pointer; transition: all .18s;
  }
  .btn-complete:hover { background: #1d4ed8; color: #fff; border-color: #1d4ed8; }
  .badge-completed { background: #dcfce7 !important; color: #16a34a !important; }

  .btn-review {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 7px 14px; border-radius: 8px;
    background: #fef3c7; color: #d97706;
    border: 1.5px solid #fde68a;
    font-size: 12px; font-weight: 700; font-family: inherit;
    text-decoration: none; transition: all .18s;
  }
  .btn-review:hover { background: #d97706; color: #fff; border-color: #d97706; }
  .badge-reviewed { background: #f3e8ff !important; color: #7c3aed !important; }

  /* ══════════════════════════════
     SESSION CARD (in header)
  ══════════════════════════════ */
  .session-card {
    margin: 0 24px 14px;
    border-radius: var(--radius);
    border: 1.5px solid var(--border);
    background: linear-gradient(135deg, #F5F3FF 0%, #EEF2FF 100%);
    padding: 13px 16px;
    display: flex;
    align-items: center;
    gap: 14px;
    position: relative;
    overflow: hidden;
  }
  .session-card::before {
    content: '';
    position: absolute; left: 0; top: 0; bottom: 0;
    width: 4px;
    background: var(--brand);
    border-radius: 4px 0 0 4px;
  }
  .session-card.live {
    background: linear-gradient(135deg, #ECFDF5 0%, #D1FAE5 100%);
    border-color: rgba(16,185,129,.3);
  }
  .session-card.live::before { background: #10B981; }
  .session-card.over {
    background: var(--bg);
    border-color: var(--border);
    opacity: .75;
  }
  .session-card.over::before { background: var(--muted); }

  .session-card-icon {
    width: 40px; height: 40px; border-radius: 12px;
    background: var(--brand-glow);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .session-card.live .session-card-icon { background: rgba(16,185,129,.15); }
  .session-card-icon svg { width: 18px; height: 18px; color: var(--brand); }
  .session-card.live .session-card-icon svg { color: #10B981; }

  .session-card-info { flex: 1; min-width: 0; }
  .session-card-info h4 {
    font-size: 13px; font-weight: 700; color: var(--text);
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .session-card-meta {
    display: flex; align-items: center; gap: 10px;
    margin-top: 3px; flex-wrap: wrap;
  }
  .session-card-meta span {
    font-size: 11px; color: var(--muted);
    display: flex; align-items: center; gap: 3px;
  }
  .session-card-meta svg { width: 11px; height: 11px; }

  .live-badge {
    background: #10B981; color: #fff;
    font-size: 10px; font-weight: 800;
    padding: 2px 8px; border-radius: 50px;
    letter-spacing: .3px;
    animation: pulseBadge 1.5s infinite;
  }
  @keyframes pulseBadge {
    0%,100% { opacity:1; } 50% { opacity:.7; }
  }

  .session-card-right { display: flex; align-items: center; gap: 8px; flex-shrink: 0; }

  /* Join button */
  .btn-join {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 8px 16px; border-radius: 50px;
    font-size: 12px; font-weight: 700;
    border: none; cursor: pointer;
    text-decoration: none; transition: all .2s;
    white-space: nowrap;
  }
  .btn-join.active {
    background: #10B981; color: #fff;
    box-shadow: 0 4px 14px rgba(16,185,129,.35);
  }
  .btn-join.active:hover {
    background: #059669;
    box-shadow: 0 6px 18px rgba(16,185,129,.45);
    transform: translateY(-1px);
  }
  .btn-join.inactive {
    background: var(--border); color: var(--muted);
    cursor: not-allowed; pointer-events: none;
  }
  .btn-join svg { width: 13px; height: 13px; }

  /* Edit session link */
  .btn-edit-session {
    width: 30px; height: 30px; border-radius: 50%;
    border: 1.5px solid var(--border);
    display: flex; align-items: center; justify-content: center;
    color: var(--muted); text-decoration: none;
    transition: all .2s; flex-shrink: 0;
  }
  .btn-edit-session:hover { border-color: var(--brand); color: var(--brand); }
  .btn-edit-session svg { width: 13px; height: 13px; }

  /* Countdown */
  .session-countdown {
    font-size: 11px; font-weight: 700;
    color: var(--brand); background: var(--brand-glow);
    padding: 3px 8px; border-radius: 50px;
  }

  /* ══════════════════════════════
     MESSAGES AREA
  ══════════════════════════════ */
  .messages-area {
    flex: 1; overflow-y: auto;
    padding: 20px 24px;
    display: flex; flex-direction: column; gap: 10px;
  }
  .messages-area::-webkit-scrollbar { width: 4px; }
  .messages-area::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }

  .chat-empty {
    flex: 1; display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    gap: 10px; color: var(--muted); padding: 40px 0;
  }
  .chat-empty-icon {
    width: 56px; height: 56px; border-radius: 50%;
    background: var(--brand-glow);
    display: flex; align-items: center; justify-content: center; margin-bottom: 4px;
  }
  .chat-empty-icon svg { width: 26px; height: 26px; color: var(--brand); }
  .chat-empty p { font-size: 14px; }

  .message-row { display: flex; align-items: flex-end; gap: 8px; }
  .message-row.mine { flex-direction: row-reverse; }

  .msg-avatar {
    width: 28px; height: 28px; border-radius: 50%;
    object-fit: cover; flex-shrink: 0;
  }
  .msg-avatar-fb {
    width: 28px; height: 28px; border-radius: 50%;
    background: linear-gradient(135deg, var(--brand), var(--brand-2));
    color: #fff; font-size: 11px; font-weight: 700;
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  }

  .bubble {
    max-width: 60%; padding: 10px 14px; border-radius: 18px;
    font-size: 14px; line-height: 1.55; word-break: break-word;
  }
  .bubble .time {
    font-size: 10px; opacity: .55;
    margin-top: 4px; display: block; text-align: right;
  }
  .message-row.theirs .bubble {
    background: var(--surface); color: var(--text);
    border-bottom-left-radius: 4px;
    border: 1px solid var(--border); box-shadow: var(--shadow-sm);
  }
  .message-row.mine .bubble {
    background: var(--brand); color: #fff;
    border-bottom-right-radius: 4px;
    box-shadow: 0 4px 14px rgba(124,58,237,.25);
  }
  .message-row.mine .bubble .time { color: rgba(255,255,255,.6); }

  /* ══════════════════════════════
     INPUT AREA
  ══════════════════════════════ */
  .typing-bar {
    padding: 2px 24px 4px;
    font-size: 12px; color: var(--muted); min-height: 20px; flex-shrink: 0;
  }

  .chat-input-area {
    background: var(--surface);
    border-top: 1.5px solid var(--border);
    padding: 12px 20px;
    display: flex; align-items: center; gap: 10px; flex-shrink: 0;
  }
  .chat-input-area textarea {
    flex: 1; border: 1.5px solid var(--border); border-radius: 50px;
    padding: 10px 18px; font-size: 14px; font-family: var(--font-body);
    resize: none; outline: none; max-height: 100px; line-height: 1.4;
    background: var(--bg); color: var(--text);
    transition: border-color .2s, box-shadow .2s;
  }
  .chat-input-area textarea:focus {
    border-color: var(--brand);
    box-shadow: 0 0 0 3px var(--brand-glow);
    background: #fff;
  }
  .chat-input-area textarea::placeholder { color: var(--muted); }

  .send-btn {
    width: 44px; height: 44px; border-radius: 50%;
    background: var(--brand); border: none; cursor: pointer;
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    box-shadow: 0 4px 14px rgba(124,58,237,.3);
    transition: all .2s;
  }
  .send-btn:hover { background: #6D28D9; transform: translateY(-1px); }
  .send-btn:active { transform: scale(.95); }
  .send-btn svg { width: 18px; height: 18px; fill: #fff; }

  /* ── Responsive ── */
  @media (max-width: 767px) {
    .chat-header-main { padding: 11px 16px; }
    .session-card { margin: 0 16px 12px; }
    .messages-area { padding: 16px; }
    .typing-bar { padding: 2px 16px 4px; }
    .chat-input-area { padding: 10px 14px; }
    .bubble { max-width: 82%; }
    .btn-schedule span { display: none; }
  }
</style>

<div class="chat-page">

  <!-- ── Header ── -->
  <div class="chat-header">
    <div class="chat-header-main">
      <a href="/chats" class="chat-back">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M19 12H5M12 19l-7-7 7-7"/>
        </svg>
      </a>

      <% if (otherUser.profilePic) { %>
        <img class="chat-header-avatar" src="<%= otherUser.profilePic %>" alt="<%= otherUser.name %>"/>
      <% } else { %>
        <div class="chat-header-avatar-fb"><%= otherUser.name.charAt(0).toUpperCase() %></div>
      <% } %>

      <div class="chat-header-info">
        <h3><%= otherUser.name %></h3>
        <p>Swap partner</p>
      </div>

      <div class="chat-header-actions">
        <% if (swap.status === 'completed') { %>
          <span class="chat-header-badge badge-completed">
            <svg width="9" height="9" viewBox="0 0 24 24" fill="currentColor"><path d="M20 6L9 17l-5-5"/></svg>
            Completed
          </span>
          <% if (hasReviewed) { %>
            <span class="chat-header-badge badge-reviewed">Review submitted</span>
          <% } else { %>
            <a href="/reviews/write/<%= swap._id %>" class="btn-review">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" width="13" height="13">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
              </svg>
              <span>Write Review</span>
            </a>
          <% } %>
        <% } else { %>
          <span class="chat-header-badge">
            <svg width="9" height="9" viewBox="0 0 24 24" fill="currentColor"><path d="M20 6L9 17l-5-5"/></svg>
            Accepted
          </span>
          <a href="/sessions/<%= swap._id %>/schedule" class="btn-schedule">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
            <span>Schedule</span>
          </a>
          <form action="/swaps/<%= swap._id %>/complete" method="POST" class="complete-form" onsubmit="return confirm('Mark this swap as completed?')">
            <button type="submit" class="btn-complete">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
              <span>Complete</span>
            </button>
          </form>
        <% } %>
      </div>
    </div>

    <!-- Session card (rendered server-side, updated via JS) -->
    <div id="sessionCardWrap">
      <% if (session) {
        const now = new Date();
        const start = new Date(session.scheduledAt);
        const end   = new Date(start.getTime() + session.duration * 60 * 1000);
        const isLive = now >= start && now <= end;
        const isOver = now > end;
        const dateStr = start.toLocaleDateString('en-US',{ weekday:'short', month:'short', day:'numeric' });
        const timeStr = start.toLocaleTimeString('en-US',{ hour:'2-digit', minute:'2-digit' });
        const cardClass = isLive ? 'live' : isOver ? 'over' : '';
      %>
      <div class="session-card <%= cardClass %>" id="sessionCard">
        <div class="session-card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
        </div>
        <div class="session-card-info">
          <h4><%= session.title %></h4>
          <div class="session-card-meta">
            <span>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              <%= dateStr %> · <%= timeStr %>
            </span>
            <span>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/></svg>
              <%= session.duration %> min
            </span>
            <% if (isLive) { %><span class="live-badge">● LIVE NOW</span><% } %>
            <% if (isOver) { %><span style="color:var(--muted);font-style:italic">Session ended</span><% } %>
          </div>
        </div>
        <div class="session-card-right">
          <% if (!isOver) { %>
            <span class="session-countdown" id="sessionCountdown"></span>
          <% } %>
          <% if (session.meetLink && !isOver) { %>
            <a
              href="<%= isLive ? session.meetLink : '#' %>"
              target="<%= isLive ? '_blank' : '_self' %>"
              class="btn-join <%= isLive ? 'active' : 'inactive' %>"
              id="joinBtn"
              data-link="<%= session.meetLink %>"
              data-start="<%= start.getTime() %>"
              data-end="<%= end.getTime() %>"
            >
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/>
              </svg>
              <%= isLive ? 'Join Now' : 'Join Meeting' %>
            </a>
          <% } %>
          <a href="/sessions/<%= swap._id %>/schedule" class="btn-edit-session" title="Edit session">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/>
            </svg>
          </a>
        </div>
      </div>
      <% } %>
    </div>
  </div>

  <!-- ── Messages ── -->
  <div class="messages-area" id="messagesArea">
    <% if (chat.messages.length === 0) { %>
      <div class="chat-empty">
        <div class="chat-empty-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>
          </svg>
        </div>
        <p>No messages yet — say hello! 👋</p>
      </div>
    <% } else { %>
      <% chat.messages.forEach(msg => {
        const isMine = msg.sender._id
          ? msg.sender._id.toString() === currentUser._id.toString()
          : msg.sender.toString() === currentUser._id.toString();
        const senderPic  = isMine ? (currentUser.profilePic || null) : (otherUser.profilePic || null);
        const senderName = isMine ? currentUser.name : otherUser.name;
        const timeStr    = new Date(msg.createdAt).toLocaleTimeString([], { hour:'2-digit', minute:'2-digit' });
      %>
      <div class="message-row <%= isMine ? 'mine' : 'theirs' %>">
        <% if (senderPic) { %>
          <img class="msg-avatar" src="<%= senderPic %>" alt="<%= senderName %>"/>
        <% } else { %>
          <div class="msg-avatar-fb"><%= senderName.charAt(0).toUpperCase() %></div>
        <% } %>
        <div class="bubble">
          <%= msg.content %>
          <span class="time"><%= timeStr %></span>
        </div>
      </div>
      <% }) %>
    <% } %>
  </div>

  <div class="typing-bar" id="typingBar"></div>

  <!-- ── Input ── -->
  <div class="chat-input-area">
    <textarea id="messageInput" placeholder="Type a message..." rows="1"></textarea>
    <button class="send-btn" id="sendBtn">
      <svg viewBox="0 0 24 24"><path d="M2 21L23 12 2 3v7l15 2-15 2v7z"/></svg>
    </button>
  </div>

</div>

<script src="/socket.io/socket.io.js"></script>
<script>
  const chatId    = '<%= chat._id %>';
  const swapId    = '<%= swap._id %>';
  const myId      = '<%= currentUser._id %>';
  const myName    = '<%= currentUser.name %>';
  const myPic     = '<%= currentUser.profilePic || "" %>';
  const otherPic  = '<%= otherUser.profilePic || "" %>';
  const otherName = '<%= otherUser.name %>';

  // ── Socket.io ──
  const socket  = io();
  const area    = document.getElementById('messagesArea');
  const input   = document.getElementById('messageInput');
  const sendBtn = document.getElementById('sendBtn');
  const typingEl= document.getElementById('typingBar');

  socket.emit('joinRoom', { chatId, userId: myId });

  function scrollBottom() { area.scrollTop = area.scrollHeight; }
  scrollBottom();

  function escapeHtml(t) {
    return t.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function buildBubble(msg) {
    const isMine = msg.senderId === myId;
    const pic    = isMine ? myPic : otherPic;
    const name   = isMine ? myName : otherName;
    const time   = new Date(msg.createdAt).toLocaleTimeString([], { hour:'2-digit', minute:'2-digit' });
    const empty  = area.querySelector('.chat-empty');
    if (empty) empty.remove();

    const row = document.createElement('div');
    row.className = `message-row ${isMine ? 'mine' : 'theirs'}`;
    const av = pic
      ? `<img class="msg-avatar" src="${pic}" alt="${escapeHtml(name)}"/>`
      : `<div class="msg-avatar-fb">${escapeHtml(name.charAt(0).toUpperCase())}</div>`;
    row.innerHTML = `${av}<div class="bubble">${escapeHtml(msg.content)}<span class="time">${time}</span></div>`;
    area.appendChild(row);
    scrollBottom();
  }

  function sendMessage() {
    const content = input.value.trim();
    if (!content) return;
    socket.emit('sendMessage', { chatId, senderId: myId, content });
    input.value = '';
    input.style.height = 'auto';
    stopTyping();
  }

  sendBtn.addEventListener('click', sendMessage);
  input.addEventListener('keydown', e => {
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); }
  });
  input.addEventListener('input', () => {
    input.style.height = 'auto';
    input.style.height = Math.min(input.scrollHeight, 100) + 'px';
  });

  socket.on('receiveMessage', buildBubble);

  let typingTimeout;
  function stopTyping() { socket.emit('stopTyping', { chatId, userId: myId }); }
  input.addEventListener('input', () => {
    socket.emit('typing', { chatId, userId: myId, name: myName });
    clearTimeout(typingTimeout);
    typingTimeout = setTimeout(stopTyping, 2000);
  });
  socket.on('userTyping',        ({ name }) => { typingEl.textContent = `${name} is typing...`; });
  socket.on('userStoppedTyping', ()         => { typingEl.textContent = ''; });
  socket.on('error',             ({ message }) => { alert('Error: ' + message); });

  // ── Session countdown + live button ──
  const joinBtn = document.getElementById('joinBtn');
  const countdownEl = document.getElementById('sessionCountdown');

  function updateSession() {
    if (!joinBtn) return;
    const start = parseInt(joinBtn.dataset.start);
    const end   = parseInt(joinBtn.dataset.end);
    const link  = joinBtn.dataset.link;
    const now   = Date.now();

    if (now >= start && now <= end) {
      // LIVE
      joinBtn.className = 'btn-join active';
      joinBtn.href = link;
      joinBtn.target = '_blank';
      joinBtn.innerHTML = `
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" width="13" height="13">
          <polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/>
        </svg> Join Now`;
      document.getElementById('sessionCard')?.classList.add('live');
      document.getElementById('sessionCard')?.classList.remove('over');
      if (countdownEl) countdownEl.textContent = '';

    } else if (now < start) {
      // upcoming — show countdown
      joinBtn.className = 'btn-join inactive';
      joinBtn.href = '#';
      joinBtn.removeAttribute('target');
      joinBtn.innerHTML = `
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" width="13" height="13">
          <polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/>
        </svg> Join Meeting`;
      document.getElementById('sessionCard')?.classList.remove('live','over');

      // Build countdown
      if (countdownEl) {
        const diff = start - now;
        const h = Math.floor(diff / 3600000);
        const m = Math.floor((diff % 3600000) / 60000);
        const s = Math.floor((diff % 60000) / 1000);
        if (h > 0)       countdownEl.textContent = `in ${h}h ${m}m`;
        else if (m > 0)  countdownEl.textContent = `in ${m}m ${s}s`;
        else             countdownEl.textContent = `in ${s}s`;
      }
    } else {
      // over
      document.getElementById('sessionCard')?.classList.add('over');
      document.getElementById('sessionCard')?.classList.remove('live');
      if (countdownEl) countdownEl.textContent = '';
    }
  }

  updateSession();
  setInterval(updateSession, 1000); // tick every second for live countdown
</script>

</body>
</html>
