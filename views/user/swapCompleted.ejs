<!DOCTYPE html>
<html lang="en">
<%- include('../partials/header', { title: 'Session Completed' }) %>
<body>
<%- include('../partials/navbar', { activePage: 'chat' }) %>
<%- include('../partials/topbar') %>

<style>
  .sc-page { padding-top: 64px; min-height: 100vh; background: var(--bg); }
  .sc-container { max-width: 520px; margin: 0 auto; padding: 60px 24px 80px; text-align: center; }
  .sc-icon {
    width: 80px; height: 80px; border-radius: 50%;
    background: linear-gradient(135deg, #D1FAE5, #A7F3D0);
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 24px;
  }
  .sc-icon svg { width: 36px; height: 36px; color: #059669; }
  .sc-container h1 {
    font-family: var(--font-display); font-size: 26px; font-weight: 800;
    color: var(--text); margin-bottom: 8px;
  }
  .sc-container .sub {
    font-size: 14px; color: var(--muted); line-height: 1.6; margin-bottom: 32px;
  }
  .sc-other {
    display: flex; align-items: center; justify-content: center; gap: 10px;
    margin-bottom: 32px;
  }
  .sc-other img {
    width: 36px; height: 36px; border-radius: 50%; object-fit: cover;
  }
  .sc-other .fb {
    width: 36px; height: 36px; border-radius: 50%;
    background: linear-gradient(135deg, var(--brand), var(--brand-2));
    color: #fff; font-weight: 700; font-size: 14px;
    display: flex; align-items: center; justify-content: center;
  }
  .sc-other span { font-size: 14px; font-weight: 600; color: var(--text); }
  .sc-actions { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .btn-sc-primary, .btn-sc-secondary {
    display: inline-flex; align-items: center; gap: 7px;
    padding: 11px 24px; border-radius: 50px;
    font-size: 13px; font-weight: 700; font-family: inherit;
    text-decoration: none; cursor: pointer; transition: all .2s;
    border: none;
  }
  .btn-sc-primary {
    background: var(--brand); color: #fff;
    box-shadow: 0 4px 14px rgba(124,58,237,.3);
  }
  .btn-sc-primary:hover { background: #6d28d9; transform: translateY(-1px); }
  .btn-sc-secondary {
    background: var(--surface); color: var(--text);
    border: 1.5px solid var(--border);
  }
  .btn-sc-secondary:hover { border-color: var(--brand); color: var(--brand); }
</style>

<div class="sc-page">
  <div class="sc-container">
    <div class="sc-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/>
        <polyline points="22 4 12 14.01 9 11.01"/>
      </svg>
    </div>
    <h1>Session Completed!</h1>
    <p class="sub">Thanks for your review. Your feedback helps the SkillSwap community grow.<br>Swap completed with <strong><%= otherUser.name %></strong></p>

    <div class="sc-other">
      <% if (otherUser.profilePic) { %>
        <img src="<%= otherUser.profilePic %>" alt="<%= otherUser.name %>"/>
      <% } else { %>
        <div class="fb"><%= otherUser.name.charAt(0).toUpperCase() %></div>
      <% } %>
      <span><%= otherUser.name %></span>
    </div>

    <div class="sc-actions">
      <a href="/dashboard" class="btn-sc-primary">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="15" height="15">
          <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
          <polyline points="9 22 9 12 15 12 15 22"/>
        </svg>
        Go to Dashboard
      </a>
      <a href="/profile/users/<%= otherUser._id %>" class="btn-sc-secondary">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="15" height="15">
          <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/>
        </svg>
        View Profile
      </a>
    </div>
  </div>
</div>
</body>
</html>