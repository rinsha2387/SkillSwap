<%- include('../partials/header', { title: 'Create Group Session' }) %>
<%- include('../partials/navbar', { activePage: 'explore' }) %>
<%- include('../partials/topbar') %>

<style>
  .cgs-page { padding-top: 64px; min-height: 100vh; background: var(--bg); }
  .cgs-container { max-width: 660px; margin: 0 auto; padding: 32px 24px 80px; }

  .cgs-toprow { display: flex; align-items: center; gap: 14px; margin-bottom: 28px; }
  .cgs-back {
    width: 38px; height: 38px; border-radius: 50%;
    border: 1.5px solid var(--border);
    display: flex; align-items: center; justify-content: center;
    color: var(--muted); text-decoration: none; transition: all .2s; flex-shrink: 0;
  }
  .cgs-back:hover { border-color: var(--brand); color: var(--brand); }
  .cgs-toprow h1 { font-family: var(--font-display); font-size: 21px; font-weight: 800; color: var(--text); }
  .cgs-toprow p  { font-size: 13px; color: var(--muted); margin-top: 2px; }

  .cgs-card {
    background: var(--surface); border: 1.5px solid var(--border);
    border-radius: var(--radius-lg); padding: 30px; box-shadow: var(--shadow-sm);
  }

  .form-section { margin-bottom: 28px; }
  .form-section-title {
    font-family: var(--font-display); font-size: 13px; font-weight: 700;
    color: var(--muted); text-transform: uppercase; letter-spacing: .6px;
    margin-bottom: 16px; display: flex; align-items: center; gap: 7px;
    padding-bottom: 10px; border-bottom: 1.5px solid var(--border);
  }
  .form-section-title svg { width: 14px; height: 14px; color: var(--brand); }

  .form-row { margin-bottom: 18px; }
  .form-row label {
    display: block; font-size: 12px; font-weight: 700;
    color: var(--muted); text-transform: uppercase; letter-spacing: .5px; margin-bottom: 7px;
  }
  .form-row input,
  .form-row select,
  .form-row textarea {
    width: 100%; border: 1.5px solid var(--border); border-radius: var(--radius-sm);
    padding: 11px 14px; font-size: 14px; font-family: var(--font-body);
    color: var(--text); background: var(--bg); outline: none;
    transition: border-color .2s, box-shadow .2s;
  }
  .form-row input:focus,
  .form-row select:focus,
  .form-row textarea:focus {
    border-color: var(--brand); box-shadow: 0 0 0 3px var(--brand-glow); background: #fff;
  }
  .form-row textarea { resize: vertical; min-height: 90px; }
  .form-grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .form-grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; }

  /* Free / Paid toggle */
  .price-toggle { display: flex; gap: 10px; margin-bottom: 16px; }
  .ptog-btn {
    flex: 1; padding: 11px; border-radius: var(--radius-sm);
    border: 1.5px solid var(--border); background: var(--bg);
    font-size: 13px; font-weight: 700; color: var(--muted);
    cursor: pointer; transition: all .2s; font-family: inherit;
    display: flex; align-items: center; justify-content: center; gap: 7px;
  }
  .ptog-btn.active-free  { border-color: var(--green); background: rgba(16,185,129,.08); color: #059669; }
  .ptog-btn.active-paid  { border-color: var(--brand); background: var(--brand-glow); color: var(--brand); }
  .price-input-row { display: none; }
  .price-input-row.visible { display: block; }

  /* Jitsi note */
  .jitsi-note {
    background: linear-gradient(135deg, #EEF2FF, #F5F3FF);
    border: 1.5px solid rgba(79,70,229,.18);
    border-radius: var(--radius-sm); padding: 12px 16px;
    display: flex; align-items: center; gap: 10px; margin-top: 6px;
  }
  .jitsi-note svg { width: 15px; height: 15px; color: var(--brand); flex-shrink: 0; }
  .jitsi-note p { font-size: 12px; color: var(--brand); font-weight: 600; }
  .jitsi-note span { font-size: 11px; color: var(--muted); }

  .cgs-submit-row { display: flex; gap: 12px; margin-top: 28px; }
  .cgs-submit-row .btn { flex: 1; justify-content: center; padding: 14px; font-size: 14px; }

  @media (max-width: 600px) {
    .cgs-container { padding: 20px 16px 80px; }
    .cgs-card { padding: 20px; }
    .form-grid-2, .form-grid-3 { grid-template-columns: 1fr; }
    .cgs-submit-row { flex-direction: column; }
  }
</style>

<div class="cgs-page">
<div class="cgs-container">

  <div class="cgs-toprow">
    <a href="/explore" class="cgs-back">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M19 12H5M12 19l-7-7 7-7"/>
      </svg>
    </a>
    <div>
      <h1>🎓 Create Group Session</h1>
      <p>Host a live session and teach your skills</p>
    </div>
  </div>

  <div class="cgs-card">
    <form action="/group-sessions/new" method="POST">

      <!-- ── Basic Info ── -->
      <div class="form-section">
        <div class="form-section-title">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          Basic Info
        </div>
        <div class="form-row">
          <label>Session Title *</label>
          <input type="text" name="title" placeholder="e.g. Intro to React Hooks" required maxlength="80"/>
        </div>
        <div class="form-row">
          <label>Description</label>
          <textarea name="description" placeholder="What will participants learn? What should they prepare?"></textarea>
        </div>
        <div class="form-grid-2">
          <div class="form-row">
            <label>Skill Being Taught *</label>
            <input type="text" name="skillTaught" placeholder="e.g. React, Figma, Python" required/>
          </div>
          <div class="form-row">
            <label>Level</label>
            <select name="level">
              <option value="Beginner">Beginner</option>
              <option value="Intermediate">Intermediate</option>
              <option value="Advanced">Advanced</option>
            </select>
          </div>
        </div>
      </div>

      <!-- ── Schedule ── -->
      <div class="form-section">
        <div class="form-section-title">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          Schedule
        </div>
        <div class="form-grid-2">
          <div class="form-row">
            <label>Date & Time *</label>
            <input type="datetime-local" name="scheduledAt" required min="<%= new Date().toISOString().slice(0,16) %>"/>
          </div>
          <div class="form-row">
            <label>Duration</label>
            <select name="duration">
              <option value="30">30 minutes</option>
              <option value="45">45 minutes</option>
              <option value="60" selected>1 hour</option>
              <option value="90">1.5 hours</option>
              <option value="120">2 hours</option>
            </select>
          </div>
        </div>
        <div class="form-row">
          <label>Max Participants</label>
          <input type="number" name="maxParticipants" value="10" min="2" max="100"/>
        </div>

        <!-- Jitsi note -->
        <div class="jitsi-note">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/>
          </svg>
          <div>
            <p>Meeting link auto-generated at session time</p>
            <span>A private Jitsi room is created only when the session goes live</span>
          </div>
        </div>
      </div>

      <!-- ── Pricing ── -->
      <div class="form-section">
        <div class="form-section-title">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
          Pricing
        </div>
        <input type="hidden" name="isFree" id="isFreeInput" value="false"/>
        <div class="price-toggle">
          <button type="button" class="ptog-btn active-free" id="btnFree" onclick="setPricing(true)">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            Free Session
          </button>
          <button type="button" class="ptog-btn" id="btnPaid" onclick="setPricing(false)">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
            Paid Session
          </button>
        </div>
        <div class="price-input-row" id="priceInputRow">
          <div class="form-row">
            <label>Price (₹ INR)</label>
            <input type="number" name="price" id="priceInput" placeholder="e.g. 299" min="1" step="1"/>
          </div>
        </div>
      </div>

      <div class="cgs-submit-row">
        <a href="/explore" class="btn btn-outline">Cancel</a>
        <button type="submit" class="btn btn-primary">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          Create Session
        </button>
      </div>
    </form>
  </div>

</div>
</div>

<script>
  function setPricing(free) {
    document.getElementById('isFreeInput').value = free ? 'true' : 'false';
    document.getElementById('btnFree').className = 'ptog-btn' + (free ? ' active-free' : '');
    document.getElementById('btnPaid').className = 'ptog-btn' + (!free ? ' active-paid' : '');
    document.getElementById('priceInputRow').className = 'price-input-row' + (free ? '' : ' visible');
    document.getElementById('priceInput').required = !free;
  }
  // Default free
  setPricing(true);
</script>

<%- include('../partials/footer') %>
