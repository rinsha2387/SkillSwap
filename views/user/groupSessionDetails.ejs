<%- include('../partials/header', { title: session.title }) %>
<%- include('../partials/navbar', { activePage: 'explore' }) %>
<%- include('../partials/topbar') %>

<style>
  .gsd-page { padding-top: 64px; min-height: 100vh; background: var(--bg); }
  .gsd-container { max-width: 800px; margin: 0 auto; padding: 32px 24px 80px; }

  /* ── Back row ── */
  .gsd-backrow { display: flex; align-items: center; gap: 12px; margin-bottom: 24px; }
  .gsd-back {
    width: 36px; height: 36px; border-radius: 50%;
    border: 1.5px solid var(--border);
    display: flex; align-items: center; justify-content: center;
    color: var(--muted); text-decoration: none; transition: all .2s;
  }
  .gsd-back:hover { border-color: var(--brand); color: var(--brand); }

  /* ── Status banner ── */
  .gsd-status-banner {
    border-radius: var(--radius); padding: 14px 20px;
    display: flex; align-items: center; gap: 12px;
    margin-bottom: 20px; font-size: 13px; font-weight: 600;
  }
  .gsd-status-banner.scheduled {
    background: rgba(124,58,237,.07); border: 1.5px solid rgba(124,58,237,.2); color: var(--brand);
  }
  .gsd-status-banner.active {
    background: rgba(16,185,129,.08); border: 1.5px solid rgba(16,185,129,.3); color: #059669;
    animation: glowPulse 2s infinite;
  }
  @keyframes glowPulse {
    0%,100% { box-shadow: 0 0 0 0 rgba(16,185,129,0); }
    50%      { box-shadow: 0 0 0 6px rgba(16,185,129,.12); }
  }
  .gsd-status-banner.ended    { background: var(--bg); border: 1.5px solid var(--border); color: var(--muted); }
  .gsd-status-banner.cancelled{ background: rgba(239,68,68,.06); border: 1.5px solid rgba(239,68,68,.2); color: var(--red); }
  .status-dot {
    width: 9px; height: 9px; border-radius: 50%; flex-shrink: 0;
    background: currentColor;
  }
  .status-dot.pulse { animation: pulse 1.4s infinite; }
  @keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.5;transform:scale(1.4)} }
  .status-countdown { margin-left: auto; font-size: 13px; font-weight: 800; }

  /* ── Main card ── */
  .gsd-main {
    background: var(--surface); border: 1.5px solid var(--border);
    border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow-sm);
    margin-bottom: 20px;
  }

  /* Header gradient */
  .gsd-hero {
    background: linear-gradient(135deg, var(--brand) 0%, var(--brand-2) 100%);
    padding: 28px 28px 24px;
    position: relative; overflow: hidden;
  }
  .gsd-hero::before {
    content: ''; position: absolute; top: -40px; right: -40px;
    width: 180px; height: 180px; border-radius: 50%;
    background: rgba(255,255,255,.07);
  }
  .gsd-hero-top { display: flex; align-items: flex-start; gap: 14px; margin-bottom: 16px; }
  .gsd-level-badge {
    background: rgba(255,255,255,.2); color: #fff;
    font-size: 11px; font-weight: 700; padding: 4px 12px; border-radius: 50px;
    letter-spacing: .3px;
  }
  .gsd-price-badge {
    margin-left: auto;
    font-size: 16px; font-weight: 800; color: #fff;
  }
  .gsd-price-badge.free {
    background: rgba(16,185,129,.3); font-size: 12px; font-weight: 700;
    padding: 5px 14px; border-radius: 50px;
  }
  .gsd-title {
    font-family: var(--font-display); font-size: 22px; font-weight: 800;
    color: #fff; line-height: 1.3; margin-bottom: 8px;
  }
  .gsd-skill-tag {
    display: inline-flex; align-items: center; gap: 5px;
    background: rgba(255,255,255,.15); color: rgba(255,255,255,.9);
    font-size: 12px; font-weight: 600; padding: 4px 12px; border-radius: 50px;
  }

  /* Body */
  .gsd-body { padding: 24px 28px; }

  /* Host row */
  .gsd-host-row {
    display: flex; align-items: center; gap: 12px;
    padding-bottom: 18px; border-bottom: 1.5px solid var(--border); margin-bottom: 20px;
  }
  .gsd-host-avatar {
    width: 44px; height: 44px; border-radius: 50%;
    object-fit: cover; border: 2px solid var(--brand);
  }
  .gsd-host-avatar-fb {
    width: 44px; height: 44px; border-radius: 50%;
    background: linear-gradient(135deg, var(--brand), var(--brand-2));
    color: #fff; font-size: 16px; font-weight: 700;
    display: flex; align-items: center; justify-content: center;
  }
  .gsd-host-info p { font-size: 14px; font-weight: 700; color: var(--text); }
  .gsd-host-info span { font-size: 12px; color: var(--muted); }

  /* Info grid */
  .gsd-info-grid {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 14px; margin-bottom: 22px;
  }
  .gsd-info-item {
    background: var(--bg); border-radius: var(--radius-sm);
    padding: 14px; display: flex; flex-direction: column; gap: 4px;
  }
  .gsd-info-item span { font-size: 10px; font-weight: 700; color: var(--muted); text-transform: uppercase; letter-spacing: .5px; }
  .gsd-info-item p { font-size: 14px; font-weight: 700; color: var(--text); }

  /* Description */
  .gsd-desc { font-size: 14px; color: #4b5563; line-height: 1.65; margin-bottom: 22px; }

  /* Participants */
  .gsd-participants-section { margin-bottom: 22px; }
  .gsd-participants-section h4 {
    font-size: 12px; font-weight: 700; color: var(--muted);
    text-transform: uppercase; letter-spacing: .5px; margin-bottom: 10px;
  }
  .gsd-participants-row { display: flex; align-items: center; gap: -6px; }
  .gsd-p-avatar {
    width: 30px; height: 30px; border-radius: 50%;
    border: 2px solid var(--surface); object-fit: cover; margin-left: -6px;
  }
  .gsd-p-avatar:first-child { margin-left: 0; }
  .gsd-p-avatar-fb {
    width: 30px; height: 30px; border-radius: 50%;
    background: linear-gradient(135deg, var(--brand), var(--brand-2));
    border: 2px solid var(--surface);
    color: #fff; font-size: 11px; font-weight: 700;
    display: flex; align-items: center; justify-content: center;
    margin-left: -6px;
  }
  .gsd-p-avatar-fb:first-child { margin-left: 0; }
  .gsd-spots-left {
    margin-left: 10px; font-size: 12px; font-weight: 600; color: var(--muted);
  }
  .gsd-spots-left.urgent { color: var(--red); font-weight: 700; }
  .gsd-progress {
    width: 100%; height: 6px; background: var(--border);
    border-radius: 50px; margin-top: 10px; overflow: hidden;
  }
  .gsd-progress-bar {
    height: 100%; border-radius: 50px; background: var(--brand);
    transition: width .4s ease;
  }

  /* ── Action card ── */
  .gsd-action-card {
    background: var(--surface); border: 1.5px solid var(--border);
    border-radius: var(--radius-lg); padding: 24px; box-shadow: var(--shadow-sm);
  }
  .gsd-action-card h3 {
    font-family: var(--font-display); font-size: 15px; font-weight: 700;
    color: var(--text); margin-bottom: 16px;
  }

  /* Join/pay button */
  .btn-join-session {
    width: 100%; padding: 14px; border-radius: var(--radius-sm);
    font-size: 15px; font-weight: 800; border: none; cursor: pointer;
    display: flex; align-items: center; justify-content: center; gap: 8px;
    font-family: inherit; transition: all .2s; text-decoration: none;
  }
  .btn-join-session.live {
    background: linear-gradient(135deg, #10B981, #059669);
    color: #fff; box-shadow: 0 6px 20px rgba(16,185,129,.35);
    animation: glowBtn 2s infinite;
  }
  @keyframes glowBtn { 0%,100%{box-shadow:0 6px 20px rgba(16,185,129,.35)} 50%{box-shadow:0 6px 30px rgba(16,185,129,.55)} }
  .btn-join-session.live:hover { transform: translateY(-1px); }
  .btn-join-session.pay {
    background: var(--brand); color: #fff;
    box-shadow: 0 4px 16px rgba(124,58,237,.3);
  }
  .btn-join-session.pay:hover { background: #6D28D9; transform: translateY(-1px); }
  .btn-join-session.disabled {
    background: var(--border); color: var(--muted); cursor: not-allowed;
  }
  .btn-join-session.enrolled {
    background: rgba(16,185,129,.1); color: #059669;
    border: 1.5px solid rgba(16,185,129,.3); cursor: default;
  }

  .gsd-enrolled-note {
    display: flex; align-items: center; gap: 8px;
    font-size: 13px; color: #059669; font-weight: 600;
    background: rgba(16,185,129,.08); border: 1.5px solid rgba(16,185,129,.2);
    border-radius: var(--radius-sm); padding: 10px 14px; margin-bottom: 14px;
  }
  .gsd-enrolled-note svg { width: 15px; height: 15px; flex-shrink: 0; }

  /* Host actions */
  .gsd-host-actions { display: flex; flex-direction: column; gap: 10px; }
  .btn-cancel-session {
    width: 100%; padding: 11px; border-radius: var(--radius-sm);
    border: 1.5px solid rgba(239,68,68,.3); background: rgba(239,68,68,.06);
    color: var(--red); font-size: 13px; font-weight: 700;
    cursor: pointer; font-family: inherit; transition: all .2s;
  }
  .btn-cancel-session:hover { background: rgba(239,68,68,.12); }
  .btn-end-session {
    width: 100%; padding: 11px; border-radius: var(--radius-sm);
    border: 1.5px solid rgba(16,185,129,.3); background: rgba(16,185,129,.06);
    color: #059669; font-size: 13px; font-weight: 700;
    cursor: pointer; font-family: inherit; transition: all .2s;
  }
  .btn-end-session:hover { background: rgba(16,185,129,.12); }

  /* Tags */
  .gsd-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 4px; }
  .gsd-tag {
    background: var(--bg); border: 1px solid var(--border);
    color: var(--muted); font-size: 11px; font-weight: 600;
    padding: 3px 10px; border-radius: 50px;
  }

  @media (max-width: 767px) {
    .gsd-container { padding: 20px 16px 80px; }
    .gsd-info-grid { grid-template-columns: 1fr 1fr; }
    .gsd-body { padding: 20px; }
    .gsd-hero { padding: 22px 20px 18px; }
  }
</style>

<div class="gsd-page">
<div class="gsd-container">

  <!-- Back -->
  <div class="gsd-backrow">
    <a href="/explore" class="gsd-back">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M19 12H5M12 19l-7-7 7-7"/>
      </svg>
    </a>
    <span style="font-size:13px;color:var(--muted)">Back to Explore</span>
  </div>

  <%
    const statusLabel = {
      scheduled: 'Session Scheduled',
      active:    '🔴 Live Now',
      ended:     'Session Ended',
      cancelled: 'Session Cancelled'
    }[session.status];
    const paidCount = session.participants.filter(p => p.paid || session.isFree).length;
    const fillPct   = Math.round((paidCount / session.maxParticipants) * 100);
    const spotsLeft = Math.max(0, session.maxParticipants - paidCount);
  %>

  <!-- Status banner -->
  <div class="gsd-status-banner <%= session.status %>">
    <span class="status-dot <%= session.status === 'active' ? 'pulse' : '' %>"></span>
    <%= statusLabel %>
    <% if (session.status === 'scheduled') { %>
      <span class="status-countdown" id="countdown"></span>
    <% } %>
  </div>

  <!-- Main card -->
  <div class="gsd-main">
    <!-- Hero -->
    <div class="gsd-hero">
      <div class="gsd-hero-top">
        <span class="gsd-level-badge"><%= session.level %></span>
        <% if (session.isFree) { %>
          <span class="gsd-price-badge free">FREE</span>
        <% } else { %>
          <span class="gsd-price-badge">₹<%= session.price %></span>
        <% } %>
      </div>
      <h1 class="gsd-title"><%= session.title %></h1>
      <span class="gsd-skill-tag">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
        <%= session.skillTaught %>
      </span>
    </div>

    <!-- Body -->
    <div class="gsd-body">

      <!-- Host -->
      <div class="gsd-host-row">
        <% if (session.host.profilePic) { %>
          <img class="gsd-host-avatar" src="<%= session.host.profilePic %>" alt="<%= session.host.name %>"/>
        <% } else { %>
          <div class="gsd-host-avatar-fb"><%= session.host.name.charAt(0).toUpperCase() %></div>
        <% } %>
        <div class="gsd-host-info">
          <p><%= session.host.name %></p>
          <span>Session Host</span>
        </div>
        <% if (isHost) { %>
          <span class="badge badge-purple" style="margin-left:auto">You're the host</span>
        <% } %>
      </div>

      <!-- Info grid -->
      <div class="gsd-info-grid">
        <div class="gsd-info-item">
          <span>📅 Date</span>
          <p><%= new Date(session.scheduledAt).toLocaleDateString('en-IN', { weekday:'short', month:'short', day:'numeric' }) %></p>
        </div>
        <div class="gsd-info-item">
          <span>🕐 Time</span>
          <p><%= new Date(session.scheduledAt).toLocaleTimeString('en-IN', { hour:'2-digit', minute:'2-digit' }) %></p>
        </div>
        <div class="gsd-info-item">
          <span>⏱ Duration</span>
          <p><%= session.duration >= 60 ? Math.floor(session.duration/60) + 'h' + (session.duration%60 ? ' ' + session.duration%60 + 'm':'') : session.duration + ' min' %></p>
        </div>
      </div>

      <!-- Description -->
      <% if (session.description) { %>
        <p class="gsd-desc"><%= session.description %></p>
      <% } %>

      <!-- Tags -->
      <% if (session.tags && session.tags.length) { %>
        <div class="gsd-tags" style="margin-bottom:20px">
          <% session.tags.forEach(t => { %><span class="gsd-tag">#<%= t %></span><% }) %>
        </div>
      <% } %>

      <!-- Participants -->
      <div class="gsd-participants-section">
        <h4>Participants (<%= paidCount %>/<%= session.maxParticipants %>)</h4>
        <div class="gsd-participants-row">
          <% session.participants.slice(0,8).forEach(p => { %>
            <% if (p.user && (p.paid || session.isFree)) { %>
              <% if (p.user.profilePic) { %>
                <img class="gsd-p-avatar" src="<%= p.user.profilePic %>" title="<%= p.user.name %>"/>
              <% } else { %>
                <div class="gsd-p-avatar-fb" title="<%= p.user.name %>"><%= p.user.name.charAt(0).toUpperCase() %></div>
              <% } %>
            <% } %>
          <% }) %>
          <span class="gsd-spots-left <%= spotsLeft <= 3 ? 'urgent' : '' %>">
            <%= spotsLeft === 0 ? 'Full!' : spotsLeft + ' spots left' %>
          </span>
        </div>
        <div class="gsd-progress">
          <div class="gsd-progress-bar" style="width:<%= fillPct %>%"></div>
        </div>
      </div>

    </div><!-- /gsd-body -->
  </div><!-- /gsd-main -->

  <!-- ── Action card ── -->
  <div class="gsd-action-card">
 
    <% if (isHost) { %>
      <!-- HOST VIEW -->
      <h3>Your Session</h3>
      <div class="gsd-host-actions">
        <% if (session.status === 'active') { %>
          <a href="<%= session.meetLink %>" target="_blank" class="btn-join-session live">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/>
            </svg>
            Open Your Meeting Room
          </a>
          <form action="/group-sessions/<%= session._id %>/end" method="POST"
            onsubmit="return confirm('End this session? This will mark it as completed.')">
            <button type="submit" class="btn-end-session">End Session</button>
          </form>
        <% } else if (session.status === 'scheduled') { %>
          <button class="btn-join-session disabled" disabled>
            Meeting opens at session time
          </button>
        <% } else if (session.status === 'ended') { %>
          <button class="btn-join-session disabled" disabled>Session Ended</button>
        <% } %>
        <% if (session.status === 'scheduled') { %>
          <form action="/group-sessions/<%= session._id %>/cancel" method="POST"
            onsubmit="return confirm('Cancel this session? This cannot be undone.')">
            <button type="submit" class="btn-cancel-session">Cancel Session</button>
          </form>
        <% } %>
      </div>

    <% } else if (session.status === 'cancelled' || session.status === 'ended') { %>
      <h3>Session Unavailable</h3>
      <button class="btn-join-session disabled" disabled>
        <%= session.status === 'cancelled' ? 'Session was cancelled' : 'Session has ended' %>
      </button>
      <% if (session.status === 'ended' && isEnrolled && !isHost) { %>
        <% if (hasReviewedHost) { %>
          <p style="margin-top:12px;font-size:13px;color:#7c3aed;font-weight:600;text-align:center">Review submitted ✓</p>
        <% } else { %>
          <a href="/reviews/write/group/<%= session._id %>" class="btn-join-session pay" style="margin-top:12px;text-decoration:none">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
            </svg>
            Write a Review
          </a>
        <% } %>
      <% } %>

    <% } else if (isEnrolled && (hasPaid || session.isFree)) { %>
      <!-- ENROLLED -->
      <div class="gsd-enrolled-note">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        You're enrolled in this session
      </div>
      <% if (session.status === 'active' && session.meetLink) { %>
        <a href="<%= session.meetLink %>" target="_blank" class="btn-join-session live">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/>
          </svg>
          Join Meeting Now
        </a>
      <% } else { %>
        <button class="btn-join-session enrolled" disabled>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
          Enrolled — Meeting opens at session time
        </button>
      <% } %>

    <% } else if (session.isFree) { %>
      <!-- FREE: enroll -->
      <h3>Join this free session</h3>
      <% if (spotsLeft === 0) { %>
        <button class="btn-join-session disabled" disabled>Session Full</button>
      <% } else { %>
        <form action="/group-sessions/<%= session._id %>/enroll" method="POST">
          <button type="submit" class="btn-join-session pay">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Enroll for Free
          </button>
        </form>
      <% } %>

    <% } else { %>
      <!-- ✅ PAID: Cashfree (replaced Razorpay) -->
      <h3>Get access · ₹<%= session.price %></h3>
      <% if (spotsLeft === 0) { %>
        <button class="btn-join-session disabled" disabled>Session Full</button>
      <% } else { %>
        <button class="btn-join-session pay" id="cfBtn">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/>
          </svg>
          Pay ₹<%= session.price %> & Enroll
        </button>
        <!-- ✅ Changed from Razorpay to Cashfree -->
        <p style="font-size:11px;color:var(--muted);text-align:center;margin-top:10px">
          Secured by Cashfree · UPI, Cards, Net Banking, Wallets accepted
        </p>
      <% } %>
    <% } %>

  </div><!-- /action card -->

</div>
</div>

<!-- ✅ Cashfree payment script (fully replaces Razorpay block) -->
<% if (!isHost && !session.isFree && !hasPaid && session.status !== 'cancelled' && session.status !== 'ended') { %>

<!-- ✅ Cashfree JS SDK (replaces checkout.razorpay.com script) -->
<script src="https://sdk.cashfree.com/js/v3/cashfree.js"></script>
<script>
  // ✅ cashfreeEnv from controller: 'sandbox' or 'production'
  const cashfree = Cashfree({ mode: "<%= cashfreeEnv %>" });

  const cfBtn = document.getElementById('cfBtn');

  if (cfBtn) {
    cfBtn.addEventListener('click', async function () {
      cfBtn.disabled = true;
      cfBtn.textContent = 'Processing...';

      try {
        // Step 1 — Create Cashfree order on backend
        const res = await fetch('/group-sessions/<%= session._id %>/create-order', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
        });
        const data = await res.json();

        if (data.alreadyPaid) {
          location.reload();
          return;
        }

        if (data.error || !data.paymentSessionId) {
          alert(data.error || 'Could not initialize payment. Please try again.');
          cfBtn.disabled = false;
          cfBtn.innerHTML = `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg> Pay ₹<%= session.price %> & Enroll`;
          return;
        }

        // Step 2 — Open Cashfree modal (replaces new Razorpay(options).open())
        const result = await cashfree.checkout({
          paymentSessionId: data.paymentSessionId,
          redirectTarget:   '_modal',   // opens as popup, same as Razorpay modal
        });

        if (result.error) {
          console.error('Cashfree error:', result.error);
          alert('Payment failed: ' + result.error.message);
          cfBtn.disabled = false;
          cfBtn.innerHTML = `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg> Pay ₹<%= session.price %> & Enroll`;
          return;
        }

        // Step 3 — Verify payment (replaces Razorpay signature check)
        const verifyRes = await fetch('/group-sessions/<%= session._id %>/verify-payment', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ orderId: data.orderId }),  // ✅ send orderId not signature
        });

        const verifyData = await verifyRes.json();

        if (verifyData.success) {
          window.location.href = verifyData.redirect;
        } else {
          alert('Payment verification failed. Please contact support.');
          cfBtn.disabled = false;
          cfBtn.innerHTML = `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg> Pay ₹<%= session.price %> & Enroll`;
        }

      } catch (err) {
        console.error('Payment error:', err);
        alert('Something went wrong. Please try again.');
        cfBtn.disabled = false;
        cfBtn.innerHTML = `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg> Pay ₹<%= session.price %> & Enroll`;
      }
    });
  }
</script>
<% } %>

<!-- Countdown script (unchanged) -->
<script>
  const countdownEl = document.getElementById('countdown');
  const sessionStart = <%= start.getTime() %>;
  const sessionEnd   = <%= end.getTime() %>;

  function tick() {
    if (!countdownEl) return;
    const now  = Date.now();
    const diff = sessionStart - now;
    if (diff <= 0) { location.reload(); return; }
    const h = Math.floor(diff / 3600000);
    const m = Math.floor((diff % 3600000) / 60000);
    const s = Math.floor((diff % 60000) / 1000);
    countdownEl.textContent = h > 0 ? `Starts in ${h}h ${m}m` : m > 0 ? `Starts in ${m}m ${s}s` : `Starts in ${s}s`;
  }
  tick();
  setInterval(tick, 1000);
</script>

