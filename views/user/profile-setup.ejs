<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Setup Your Profile - SkillSwap</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Inter', Arial, sans-serif;
      background: #eeeaf8;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 32px 16px;
    }

    .setup-wrapper { width: 100%; max-width: 680px; }
    .setup-header  { text-align: center; margin-bottom: 28px; }

    .logo {
      display: inline-flex; align-items: center; gap: 10px;
      margin-bottom: 24px; text-decoration: none;
    }
    .logo-icon {
      width: 40px; height: 40px; background: #6c63ff;
      border-radius: 11px; display: flex; align-items: center; justify-content: center;
    }
    .logo-icon svg { width: 22px; height: 22px; }
    .logo-text { font-size: 18px; font-weight: 700; color: #1a1340; }

    /* ── Progress Steps ── */
    .steps { display: flex; align-items: center; justify-content: center; margin-bottom: 28px; }
    .step  { display: flex; flex-direction: column; align-items: center; gap: 6px; }

    .step-circle {
      width: 32px; height: 32px; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 12px; font-weight: 700;
      border: 2px solid #e5e0f5; background: white; color: #b0a8d8;
      transition: all 0.3s; z-index: 1;
    }
    .step-label {
      font-size: 10px; font-weight: 600; color: #b0a8d8;
      text-transform: uppercase; letter-spacing: 0.06em; white-space: nowrap;
    }
    .step-line { width: 60px; height: 2px; background: #e5e0f5; margin-bottom: 18px; transition: background 0.3s; }

    .step.active .step-circle { background: #6c63ff; border-color: #6c63ff; color: white; }
    .step.active .step-label  { color: #6c63ff; }
    .step.done  .step-circle  { background: #edfaf3; border-color: #22c55e; color: #16a34a; }
    .step.done  .step-label   { color: #16a34a; }
    .step-line.done            { background: #22c55e; }

    /* ── Server Error Box ── */
    .error-box {
      background: #fff5f5; border: 1px solid #fca5a5; border-radius: 12px;
      padding: 14px 18px; margin-bottom: 20px;
      display: flex; gap: 12px; align-items: flex-start;
      animation: slideDown 0.25s ease;
    }
    @keyframes slideDown {
      from { opacity: 0; transform: translateY(-8px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .error-box-icon {
      flex-shrink: 0; width: 20px; height: 20px; background: #fee2e2;
      border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-top: 1px;
    }
    .error-box-icon svg { width: 12px; height: 12px; stroke: #dc2626; fill: none; stroke-width: 2.5; }
    .error-box-content strong { display: block; font-size: 13px; font-weight: 600; color: #dc2626; margin-bottom: 6px; }
    .error-box ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 4px; }
    .error-box ul li { font-size: 12px; color: #b91c1c; display: flex; align-items: flex-start; gap: 6px; }
    .error-box ul li::before { content: '·'; font-size: 16px; line-height: 1; color: #fca5a5; flex-shrink: 0; }

    /* ── Card ── */
    .card {
      background: white; border-radius: 20px; padding: 32px;
      border: 1px solid #ede8ff; box-shadow: 0 4px 24px rgba(108,99,255,0.08);
    }
    .card-step { display: none; }
    .card-step.active { display: block; }
    .step-heading { margin-bottom: 24px; }
    .step-heading h2 { font-size: 20px; font-weight: 700; color: #1a1340; margin-bottom: 4px; }
    .step-heading p  { font-size: 13px; color: #9b94c4; }

    /* ── Form Elements ── */
    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .form-group { display: flex; flex-direction: column; gap: 6px; }
    .form-group.full { grid-column: 1 / -1; }
    .form-label { font-size: 11px; font-weight: 600; color: #9b94c4; text-transform: uppercase; letter-spacing: 0.06em; }

    .form-input, .form-textarea {
      border: 1px solid #e5e0f5; border-radius: 10px; padding: 10px 14px;
      font-size: 13px; color: #1a1340; font-family: 'Inter', Arial, sans-serif;
      background: #faf9ff; outline: none; transition: border 0.15s, background 0.15s; width: 100%;
    }
    .form-input:focus, .form-textarea:focus { border-color: #6c63ff; background: white; }
    .form-textarea { resize: vertical; min-height: 90px; }
    .form-hint { font-size: 11px; color: #b0a8d8; }

    .form-input.input-error     { border-color: #fca5a5 !important; background: #fff5f5 !important; }
    .form-textarea.input-error  { border-color: #fca5a5 !important; background: #fff5f5 !important; }
    .tag-input-wrap.input-error { border-color: #fca5a5 !important; background: #fff5f5 !important; }
    .social-input-row.input-error { border-color: #fca5a5 !important; background: #fff5f5 !important; }

    /* ── Inline Step Toast ── */
    .step-error-toast {
      display: none; background: #fff5f5; border: 1px solid #fca5a5;
      border-radius: 10px; padding: 10px 14px; margin-top: 16px;
      gap: 8px; align-items: flex-start;
    }
    .step-error-toast.visible { display: flex; animation: slideDown 0.2s ease; }
    .step-error-toast-icon {
      flex-shrink: 0; width: 18px; height: 18px; background: #fee2e2;
      border-radius: 50%; display: flex; align-items: center; justify-content: center;
    }
    .step-error-toast-icon svg { width: 10px; height: 10px; stroke: #dc2626; fill: none; stroke-width: 3; }
    .step-error-toast ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 3px; }
    .step-error-toast ul li { font-size: 12px; color: #b91c1c; }
    .step-error-toast ul li::before { content: '· '; color: #fca5a5; }

    /* ── Photo Upload ── */
    .photo-upload-area { display: flex; align-items: center; gap: 20px; }
    .photo-preview {
      width: 80px; height: 80px; border-radius: 50%; background: #f0ebff;
      border: 2px dashed #c9c1f5; display: flex; align-items: center; justify-content: center;
      overflow: hidden; flex-shrink: 0; transition: border-color 0.2s;
    }
    .photo-preview img { width: 100%; height: 100%; object-fit: cover; display: none; }
    .photo-preview svg { width: 28px; height: 28px; stroke: #c9c1f5; fill: none; stroke-width: 1.5; }
    .photo-preview.has-image { border-color: #6c63ff; }
    .photo-preview.has-image svg { display: none; }
    .photo-preview.has-image img { display: block; }
    .photo-upload-info h4 { font-size: 14px; font-weight: 600; color: #1a1340; margin-bottom: 6px; }
    .photo-upload-info p  { font-size: 12px; color: #9b94c4; margin-bottom: 10px; }
    .upload-btn {
      display: inline-flex; align-items: center; gap: 6px; padding: 8px 16px;
      border-radius: 10px; border: 1px dashed #c9c1f5; background: #faf9ff;
      color: #6c63ff; font-size: 12px; font-weight: 500; cursor: pointer;
      font-family: 'Inter', Arial, sans-serif; transition: all 0.15s;
    }
    .upload-btn:hover { background: #f0ebff; border-color: #6c63ff; }
    .upload-btn svg { width: 13px; height: 13px; stroke: #6c63ff; fill: none; stroke-width: 2; }
    input[type="file"] { display: none; }

    /* ── Tag Input ── */
    .tag-input-wrap {
      border: 1px solid #e5e0f5; border-radius: 10px; padding: 8px 10px;
      background: #faf9ff; display: flex; flex-wrap: wrap; gap: 6px;
      min-height: 44px; cursor: text; transition: border 0.15s;
    }
    .tag-input-wrap:focus-within { border-color: #6c63ff; background: white; }
    .tag { display: inline-flex; align-items: center; gap: 5px; padding: 3px 10px; border-radius: 50px; font-size: 12px; font-weight: 500; }
    .tag-offered { background: #f0ebff; color: #6c63ff; }
    .tag-wanted  { background: #edfaf3; color: #16a34a; }
    .tag-remove  { cursor: pointer; font-size: 14px; opacity: 0.6; background: none; border: none; color: inherit; padding: 0; }
    .tag-remove:hover { opacity: 1; }
    .tag-text-input {
      border: none; outline: none; background: transparent;
      font-size: 13px; color: #1a1340; font-family: 'Inter', Arial, sans-serif; min-width: 120px; flex: 1;
    }
    .tag-text-input::placeholder { color: #c9c1f5; }

    /* ── Availability ── */
    .days-grid { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 16px; }
    .day-btn {
      padding: 7px 14px; border-radius: 50px; font-size: 12px; font-weight: 500;
      border: 1px solid #e5e0f5; background: transparent; color: #9b94c4;
      cursor: pointer; font-family: 'Inter', Arial, sans-serif; transition: all 0.15s;
    }
    .day-btn:hover    { background: #f3f0ff; color: #6c63ff; border-color: #c9c1f5; }
    .day-btn.selected { background: #6c63ff; color: white; border-color: #6c63ff; }
    .time-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }

    /* ── Social Links ── */
    .social-input-row {
      display: flex; align-items: center; gap: 10px;
      border: 1px solid #e5e0f5; border-radius: 10px; padding: 10px 14px;
      background: #faf9ff; transition: border 0.15s;
    }
    .social-input-row:focus-within { border-color: #6c63ff; background: white; }
    .social-input-row svg { width: 15px; height: 15px; stroke: #b0a8d8; fill: none; stroke-width: 2; flex-shrink: 0; }
    .social-input-row input { border: none; outline: none; background: transparent; font-size: 13px; color: #1a1340; font-family: 'Inter', Arial, sans-serif; width: 100%; }
    .social-input-row input::placeholder { color: #c9c1f5; }

    /* ── Buttons ── */
    .step-actions {
      display: flex; justify-content: space-between; align-items: center;
      margin-top: 28px; padding-top: 20px; border-top: 1px solid #f0ebff;
    }
    .btn-back {
      display: flex; align-items: center; gap: 6px; padding: 10px 20px;
      font-size: 13px; font-weight: 600; border-radius: 10px; cursor: pointer;
      border: 1px solid #e5e0f5; background: transparent; color: #9b94c4;
      font-family: 'Inter', Arial, sans-serif; transition: all 0.15s;
    }
    .btn-back:hover { background: #f3f0ff; color: #6c63ff; border-color: #c9c1f5; }
    .btn-back svg { width: 14px; height: 14px; stroke: currentColor; fill: none; stroke-width: 2; }
    .btn-next {
      display: flex; align-items: center; gap: 6px; padding: 10px 24px;
      font-size: 13px; font-weight: 600; border-radius: 10px; cursor: pointer;
      border: none; background: #6c63ff; color: white;
      font-family: 'Inter', Arial, sans-serif; transition: background 0.15s;
    }
    .btn-next:hover { background: #574fd6; }
    .btn-next svg { width: 14px; height: 14px; stroke: white; fill: none; stroke-width: 2; }
    .btn-next.green { background: #22c55e; }
    .btn-next.green:hover { background: #16a34a; }
    .step-counter { font-size: 12px; color: #b0a8d8; font-weight: 500; }

    @media (max-width: 600px) {
      .form-grid { grid-template-columns: 1fr; }
      .form-group.full { grid-column: 1; }
      .time-grid { grid-template-columns: 1fr; }
      .photo-upload-area { flex-direction: column; align-items: flex-start; }
      .step-line { width: 30px; }
    }
  </style>
</head>
<body>

<div class="setup-wrapper">

  <!-- Logo -->
  <div class="setup-header">
    <a href="/" class="logo">
      <div class="logo-icon">
        <svg viewBox="0 0 24 24" fill="none">
          <path d="M7 10L4 7L7 4" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M4 7H15C17.2 7 19 8.8 19 11" stroke="white" stroke-width="2.2" stroke-linecap="round"/>
          <path d="M17 14L20 17L17 20" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M20 17H9C6.8 17 5 15.2 5 13" stroke="white" stroke-width="2.2" stroke-linecap="round"/>
        </svg>
      </div>
      <span class="logo-text">SkillSwap</span>
    </a>

    <!-- Progress Steps -->
    <div class="steps">
      <div class="step active" id="s1"><div class="step-circle" id="sc1">1</div><div class="step-label">Basic Info</div></div>
      <div class="step-line" id="l1"></div>
      <div class="step" id="s2"><div class="step-circle" id="sc2">2</div><div class="step-label">Skills</div></div>
      <div class="step-line" id="l2"></div>
      <div class="step" id="s3"><div class="step-circle" id="sc3">3</div><div class="step-label">Availability</div></div>
      <div class="step-line" id="l3"></div>
      <div class="step" id="s4"><div class="step-circle" id="sc4">4</div><div class="step-label">Socials</div></div>
    </div>
  </div>

  <!-- Server-side error box -->
  <% if (typeof errors !== 'undefined' && errors && errors.length > 0) { %>
  <div class="error-box">
    <div class="error-box-icon">
      <svg viewBox="0 0 24 24"><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
    </div>
    <div class="error-box-content">
      <strong>Please fix the following before continuing:</strong>
      <ul><% errors.forEach(function(err){ %><li><%= err %></li><% }); %></ul>
    </div>
  </div>
  <% } %>

  <form action="/profile-setup/setup" method="POST"  id="setupForm" enctype="multipart/form-data">
    <input type="hidden" name="skillsOffered" id="skillsOfferedHidden">
    <input type="hidden" name="skillsWanted"  id="skillsWantedHidden">
    <input type="hidden" name="availability[days]" id="daysHidden">

    <div class="card">

      <!-- ══ STEP 1: Basic Info ══ -->
      <div class="card-step active" id="step1">
        <div class="step-heading">
          <h2>👋 Let's set up your profile</h2>
          <p>Tell the community who you are so we can find the right skill matches for you.</p>
        </div>

        <div class="form-grid">
          <div class="form-group full">
            <label class="form-label">Profile Photo</label>
            <div class="photo-upload-area">
              <div class="photo-preview" id="photoPreview">
                <svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                <img id="photoImg" src="" alt="Preview">
              </div>
              <div class="photo-upload-info">
                <h4>Upload a photo</h4>
                <p>JPG or PNG, max 5MB. A clear face photo helps others trust you!</p>
                <label class="upload-btn" for="photoInput">
                  <svg viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                  <span id="uploadBtnText">Choose Photo</span>
                </label>
                <input type="file" id="photoInput" name="profilePic" accept="image/*">
              </div>
            </div>
          </div>

          <div class="form-group">
            <label class="form-label">Full Name *</label>
            <input type="text" name="name" id="nameInput" class="form-input" placeholder="e.g. Rinsha K"
              value="<%= (typeof formData !== 'undefined' && formData && formData.name) ? formData.name : (user && user.name ? user.name : '') %>">
          </div>

         

          <div class="form-group full">
            <label class="form-label">Bio *</label>
            <textarea name="bio" id="bioInput" class="form-textarea" placeholder="Tell others what you're passionate about..."><%= (typeof formData !== 'undefined' && formData && formData.bio) ? formData.bio : (user && user.bio ? user.bio : '') %></textarea>
          </div>
        </div>

        <div class="step-error-toast" id="toast1">
          <div class="step-error-toast-icon"><svg viewBox="0 0 24 24"><line x1="12" y1="8" x2="12" y2="13"/><line x1="12" y1="17" x2="12" y2="17"/></svg></div>
          <ul id="toastList1"></ul>
        </div>

        <div class="step-actions">
          <span class="step-counter">Step 1 of 4</span>
          <button type="button" class="btn-next" onclick="goTo(2)">
            Next <svg viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </button>
        </div>
      </div>

      <!-- ══ STEP 2: Skills ══ -->
      <div class="card-step" id="step2">
        <div class="step-heading">
          <h2>🧠 What are your skills?</h2>
          <p>Add skills you can teach others and skills you want to learn. Press Enter or comma to add each skill.</p>
        </div>

        <div class="form-grid">
          <div class="form-group full">
            <label class="form-label">Skills You're Offering <span style="color:#b0a8d8;font-weight:400;text-transform:none">(optional)</span></label>
            <div class="tag-input-wrap" id="offeredWrap" onclick="document.getElementById('offeredInput').focus()">
              <input type="text" id="offeredInput" class="tag-text-input" placeholder="Type a skill and press Enter...">
            </div>
            <span class="form-hint">e.g. JavaScript, UI Design, Python, Photography</span>
          </div>

          <div class="form-group full">
            <label class="form-label">Skills You Want to Learn *</label>
            <div class="tag-input-wrap" id="wantedWrap" onclick="document.getElementById('wantedInput').focus()">
              <input type="text" id="wantedInput" class="tag-text-input" placeholder="Type a skill and press Enter...">
            </div>
            <span class="form-hint">e.g. Video Editing, Node.js, Public Speaking</span>
          </div>
        </div>

        <div class="step-error-toast" id="toast2">
          <div class="step-error-toast-icon"><svg viewBox="0 0 24 24"><line x1="12" y1="8" x2="12" y2="13"/><line x1="12" y1="17" x2="12" y2="17"/></svg></div>
          <ul id="toastList2"></ul>
        </div>

        <div class="step-actions">
          <button type="button" class="btn-back" onclick="_moveTo(1)">
            <svg viewBox="0 0 24 24"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg> Back
          </button>
          <div style="display:flex;align-items:center;gap:14px;">
            <span class="step-counter">Step 2 of 4</span>
            <button type="button" class="btn-next" onclick="goTo(3)">
              Next <svg viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </button>
          </div>
        </div>
      </div>

      <!-- ══ STEP 3: Availability ══ -->
      <div class="card-step" id="step3">
        <div class="step-heading">
          <h2>📅 When are you available?</h2>
          <p>Help others know the best time to book a session with you.</p>
        </div>

        <div class="form-group" style="margin-bottom:18px;">
          <label class="form-label">Available Days *</label>
          <div class="days-grid">
            <% ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'].forEach(function(day){ %>
              <button type="button" class="day-btn" data-day="<%= day %>" onclick="toggleDay(this)"><%= day.slice(0,3) %></button>
            <% }); %>
          </div>
        </div>

        <div class="time-grid">
          <div class="form-group">
            <label class="form-label">From Time</label>
            <input type="time" name="availability[from]" id="fromTime" class="form-input"
              value="<%= (typeof formData !== 'undefined' && formData && formData['availability[from]']) ? formData['availability[from]'] : '09:00' %>">
          </div>
          <div class="form-group">
            <label class="form-label">To Time</label>
            <input type="time" name="availability[to]" id="toTime" class="form-input"
              value="<%= (typeof formData !== 'undefined' && formData && formData['availability[to]']) ? formData['availability[to]'] : '18:00' %>">
          </div>
        </div>

        <div class="step-error-toast" id="toast3">
          <div class="step-error-toast-icon"><svg viewBox="0 0 24 24"><line x1="12" y1="8" x2="12" y2="13"/><line x1="12" y1="17" x2="12" y2="17"/></svg></div>
          <ul id="toastList3"></ul>
        </div>

        <div class="step-actions">
          <button type="button" class="btn-back" onclick="_moveTo(2)">
            <svg viewBox="0 0 24 24"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg> Back
          </button>
          <div style="display:flex;align-items:center;gap:14px;">
            <span class="step-counter">Step 3 of 4</span>
            <button type="button" class="btn-next" onclick="goTo(4)">
              Next <svg viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </button>
          </div>
        </div>
      </div>

      <!-- ══ STEP 4: Social Links ══ -->
      <div class="card-step" id="step4">
        <div class="step-heading">
          <h2>🔗 Add your social links</h2>
          <p>At least one social link is required — it builds trust with potential skill partners.</p>
        </div>

        <div class="form-grid">
          <div class="form-group full">
            <label class="form-label">GitHub</label>
            <div class="social-input-row" id="githubRow">
              <svg viewBox="0 0 24 24"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 00-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0020 4.77 5.07 5.07 0 0019.91 1S18.73.65 16 2.48a13.38 13.38 0 00-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 005 4.77a5.44 5.44 0 00-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 009 18.13V22"/></svg>
              <input type="text" name="github" placeholder="https://github.com/yourusername"
                value="<%= (typeof formData !== 'undefined' && formData && formData.github) ? formData.github : (user && user.socialLinks && user.socialLinks.github ? user.socialLinks.github : '') %>">
            </div>
          </div>

          <div class="form-group full">
            <label class="form-label">LinkedIn</label>
            <div class="social-input-row" id="linkedinRow">
              <svg viewBox="0 0 24 24"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
              <input type="text" name="linkedin" placeholder="https://linkedin.com/in/yourusername"
                value="<%= (typeof formData !== 'undefined' && formData && formData.linkedin) ? formData.linkedin : (user && user.socialLinks && user.socialLinks.linkedin ? user.socialLinks.linkedin : '') %>">
            </div>
          </div>

          
        </div>

        <div class="step-error-toast" id="toast4">
          <div class="step-error-toast-icon"><svg viewBox="0 0 24 24"><line x1="12" y1="8" x2="12" y2="13"/><line x1="12" y1="17" x2="12" y2="17"/></svg></div>
          <ul id="toastList4"></ul>
        </div>

        <div class="step-actions">
          <button type="button" class="btn-back" onclick="_moveTo(3)">
            <svg viewBox="0 0 24 24"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg> Back
          </button>
          <div style="display:flex;align-items:center;gap:14px;">
            <span class="step-counter">Step 4 of 4</span>
            <button type="button" class="btn-next green" onclick="handleFinish()">
              <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg> Finish Setup
            </button>
          </div>
        </div>
      </div>

    </div><!-- /.card -->
  </form>

</div><!-- /.setup-wrapper -->

<script>
  /* ══ NAVIGATION ══ */
  let currentStep = 1;
  const totalSteps = 4;

  (function autoJumpToErrorStep() {
    const serverErrors = <%- JSON.stringify(typeof errors !== 'undefined' && errors ? errors : []) %>;
    if (!serverErrors.length) return;
    const combined = serverErrors.join(' ').toLowerCase();
    let target = 1;
    if (combined.includes('github') || combined.includes('linkedin') || combined.includes('twitter')) target = 4;
    else if (combined.includes('time') || combined.includes('availability')) target = 3;
    else if (combined.includes('skill')) target = 2;
    if (target > 1) _moveTo(target);
  })();

  function goTo(step) {
    const errs = validateStep(currentStep);
    if (errs.length) { showToast(currentStep, errs); return; }
    clearToast(currentStep);
    _moveTo(step);
  }

  function _moveTo(step) {
    document.getElementById('step' + currentStep).classList.remove('active');
    for (let i = 1; i < step; i++) {
      document.getElementById('s' + i).classList.remove('active');
      document.getElementById('s' + i).classList.add('done');
      document.getElementById('sc' + i).innerHTML = '✓';
      if (i < totalSteps) document.getElementById('l' + i).classList.add('done');
    }
    for (let i = step; i <= totalSteps; i++) {
      document.getElementById('s' + i).classList.remove('done', 'active');
      document.getElementById('sc' + i).innerHTML = i;
      if (i < totalSteps && document.getElementById('l' + i))
        document.getElementById('l' + i).classList.remove('done');
    }
    document.getElementById('s' + step).classList.add('active');
    document.getElementById('step' + step).classList.add('active');
    currentStep = step;
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  /* ══ VALIDATION ══ */
  function validateStep(step) {
    const errs = [];

    if (step === 1) {
      const name     = document.getElementById('nameInput');
      const location = document.getElementById('locationInput');
      const bio      = document.getElementById('bioInput');
      const photo    = document.getElementById('photoInput');

      if (!name.value.trim()) {
        errs.push('Full name is required.'); markError(name, true);
      } else if (name.value.trim().length < 2) {
        errs.push('Name must be at least 2 characters.'); markError(name, true);
      } else { markError(name, false); }

      
     
      if (!photo.files || !photo.files[0]) {
        errs.push('Please upload a profile photo.');
        document.getElementById('photoPreview').style.border = '2px dashed #fca5a5';
      } else {
        document.getElementById('photoPreview').style.border = '';
      }
    }

    if (step === 2) {
      document.getElementById('offeredWrap').classList.remove('input-error');
      if (wantedTags.length === 0) {
        errs.push('Add at least one skill you want to learn.');
        document.getElementById('wantedWrap').classList.add('input-error');
      } else {
        document.getElementById('wantedWrap').classList.remove('input-error');
      }
    }

    if (step === 3) {
      const from = document.getElementById('fromTime');
      const to   = document.getElementById('toTime');
      if (selectedDays.length === 0) {
        errs.push('Select at least one available day.');
      }
      if (from.value && to.value && from.value >= to.value) {
        errs.push('"From" time must be earlier than "To" time.');
        markError(from, true); markError(to, true);
      } else { markError(from, false); markError(to, false); }
    }

    if (step === 4) {
      const urlPattern = /^https?:\/\/.+\..+/i;
      const fields = [
        { name: 'github',   label: 'GitHub',   rowId: 'githubRow'   },
        { name: 'linkedin', label: 'LinkedIn', rowId: 'linkedinRow' },
      ];

      const anyFilled = fields.some(f => document.querySelector(`input[name="${f.name}"]`).value.trim());

      if (!anyFilled) {
        errs.push('Please add at least one social link (GitHub, LinkedIn).');
        fields.forEach(f => markRowError(f.rowId, true));
      } else {
        fields.forEach(f => {
          const val = document.querySelector(`input[name="${f.name}"]`).value.trim();
          if (val && !urlPattern.test(val)) {
            errs.push(`${f.label} URL must start with http:// or https://`);
            markRowError(f.rowId, true);
          } else {
            markRowError(f.rowId, false);
          }
        });
      }
    }

    return errs;
  }

  /* ══ TOAST HELPERS ══ */
  function showToast(step, errs) {
    const toast = document.getElementById('toast' + step);
    const list  = document.getElementById('toastList' + step);
    list.innerHTML = errs.map(e => `<li>${e}</li>`).join('');
    toast.classList.add('visible');
  }

  function clearToast(step) {
    const t = document.getElementById('toast' + step);
    if (t) t.classList.remove('visible');
  }

  function markError(el, hasError) {
    el.classList.toggle('input-error', hasError);
  }

  function markRowError(rowId, hasError) {
    const row = document.getElementById(rowId);
    if (!row) return;
    row.classList.toggle('input-error', hasError);
  }

  /* ══ FINISH ══ */
  function handleFinish() {
    const errs = validateStep(4);
    if (errs.length) { showToast(4, errs); return; }
    clearToast(4);
    prepareSubmit();
    document.getElementById('setupForm').submit();
  }

  /* ══ PHOTO PREVIEW ══ */
  document.getElementById('photoInput').addEventListener('change', function () {
    const file = this.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = e => {
      document.getElementById('photoImg').src = e.target.result;
      document.getElementById('photoPreview').classList.add('has-image');
      document.getElementById('photoPreview').style.border = '';
      document.getElementById('uploadBtnText').textContent =
        file.name.length > 20 ? file.name.slice(0, 20) + '...' : file.name;
    };
    reader.readAsDataURL(file);
  });

  /* ══ TAG INPUT ══ */
  const offeredTags = [];
  const wantedTags  = [];

  (function restoreTags() {
    const offeredRaw = '<%- (typeof formData !== "undefined" && formData && formData.skillsOffered) ? formData.skillsOffered : "" %>';
    const wantedRaw  = '<%- (typeof formData !== "undefined" && formData && formData.skillsWanted)  ? formData.skillsWanted  : "" %>';
    if (offeredRaw) offeredRaw.split(',').map(s=>s.trim()).filter(Boolean).forEach(v =>
      addTag(v, offeredTags, document.getElementById('offeredWrap'), document.getElementById('offeredInput'), 'tag-offered'));
    if (wantedRaw)  wantedRaw.split(',').map(s=>s.trim()).filter(Boolean).forEach(v =>
      addTag(v, wantedTags,  document.getElementById('wantedWrap'),  document.getElementById('wantedInput'),  'tag-wanted'));
  })();

  function addTag(value, list, wrap, inputEl, tagClass) {
    const val = value.trim().replace(/,$/, '');
    if (!val || list.includes(val)) return;
    list.push(val);
    const tag = document.createElement('span');
    tag.className = 'tag ' + tagClass;
    const listName = list === offeredTags ? 'offeredTags' : 'wantedTags';
    tag.innerHTML = `${val} <button type="button" class="tag-remove" onclick="removeTag('${val}','${listName}',this)">×</button>`;
    wrap.insertBefore(tag, inputEl);
    inputEl.value = '';
    wrap.classList.remove('input-error');
  }

  function removeTag(val, listName, btn) {
    const list = listName === 'offeredTags' ? offeredTags : wantedTags;
    const idx  = list.indexOf(val);
    if (idx > -1) list.splice(idx, 1);
    btn.parentElement.remove();
  }

  function setupTagInput(inputId, wrapId, list, tagClass) {
    const input = document.getElementById(inputId);
    const wrap  = document.getElementById(wrapId);
    input.addEventListener('keydown', e => {
      if (e.key === 'Enter' || e.key === ',') { e.preventDefault(); addTag(input.value, list, wrap, input, tagClass); }
      if (e.key === 'Backspace' && !input.value && list.length) {
        const last  = list[list.length - 1];
        const lname = list === offeredTags ? 'offeredTags' : 'wantedTags';
        const btn   = wrap.querySelector('.tag:last-of-type .tag-remove');
        if (btn) removeTag(last, lname, btn);
      }
    });
    input.addEventListener('blur', () => { if (input.value.trim()) addTag(input.value, list, wrap, input, tagClass); });
  }

  setupTagInput('offeredInput', 'offeredWrap', offeredTags, 'tag-offered');
  setupTagInput('wantedInput',  'wantedWrap',  wantedTags,  'tag-wanted');

  /* ══ AVAILABILITY DAYS ══ */
  const selectedDays = [];

  (function restoreDays() {
    const raw = '<%- (typeof formData !== "undefined" && formData && formData["availability[days]"]) ? formData["availability[days]"] : "" %>';
    if (!raw) return;
    raw.split(',').map(d=>d.trim()).filter(Boolean).forEach(day => {
      const btn = document.querySelector(`.day-btn[data-day="${day}"]`);
      if (btn) { btn.classList.add('selected'); selectedDays.push(day); }
    });
  })();

  function toggleDay(btn) {
    const day = btn.dataset.day;
    if (btn.classList.contains('selected')) {
      btn.classList.remove('selected');
      const idx = selectedDays.indexOf(day);
      if (idx > -1) selectedDays.splice(idx, 1);
    } else {
      btn.classList.add('selected');
      selectedDays.push(day);
    }
  }

  /* ══ PREPARE SUBMIT ══ */
  function prepareSubmit() {
    document.getElementById('skillsOfferedHidden').value = offeredTags.join(',');
    document.getElementById('skillsWantedHidden').value  = wantedTags.join(',');
    document.getElementById('daysHidden').value          = selectedDays.join(',');
  }
</script>
</body>
</html>