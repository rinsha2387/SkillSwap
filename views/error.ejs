<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Error | SkillSwap</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <%- include('./partials/navbar' ,{ activePage: 'home' }) %>

  <div style="
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 80vh;
    text-align: center;
    gap: 16px;
  ">
    <h2 style="font-size: 28px;">⚠️ Oops!</h2>
    <p style="color: #666; font-size: 16px;">
      <%= message || 'Something went wrong.' %>
    </p>
    <a href="/dashboard" style="
      background: var(--brand);
      color: white;
      padding: 10px 24px;
      border-radius: 50px;
      text-decoration: none;
      font-weight: 600;
    ">Go to homePage</a>
  </div>

</body>
</html>