<header class="sk-topbar">
  <div class="sk-topbar-search">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
    </svg>
    <input type="text" placeholder="Search skills, users..." id="skSearchInput" autocomplete="off"/>
  </div>

  <div class="sk-topbar-right">
    <!-- Notification Bell -->
    <a href="/swaps/requests" id="skNotifBtn" class="sk-notif-btn" aria-label="Notifications">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/>
      </svg>
      <% if (typeof notifCount !== 'undefined' && notifCount > 0) { %>
        <span class="sk-notif-badge" id="skNotifBadge"><%= notifCount > 9 ? '9+' : notifCount %></span>
      <% } else { %>
        <span class="sk-notif-badge" id="skNotifBadge" style="display:none">0</span>
      <% } %>
    </a>

    <!-- Avatar -->
    <a href="/profile" class="sk-topbar-avatar" aria-label="Profile">
      <%
        var topbarPic  = (typeof user !== 'undefined' && user) ? (user.profilePic || user.avatar || null) : null;
        var topbarName = (typeof user !== 'undefined' && user && user.name) ? user.name : 'U';
      %>
      <% if (topbarPic) { %>
        <img src="<%= topbarPic %>" alt="<%= topbarName %>"/>
      <% } else { %>
        <div class="sk-avatar-fb"><%= topbarName.charAt(0).toUpperCase() %></div>
      <% } %>
    </a>
  </div>
</header>

<style>
  .sk-topbar {
    position: fixed;
    top: 0;
    right: 0;
    left: var(--sidebar-w);
    height: 64px;
    background: #ffffff;
    border-bottom: 1.5px solid #f0eeff;
    display: flex;
    align-items: center;
    padding: 0 28px;
    gap: 16px;
    z-index: 90;
    box-shadow: 0 2px 12px rgba(124,58,237,0.05);
  }

  /* ── Search ── */
  .sk-topbar-search {
    display: flex;
    align-items: center;
    gap: 10px;
    background: #f7f6fb;
    border: 1.5px solid #ede9fe;
    border-radius: 50px;
    padding: 0 18px;
    height: 40px;
    width: 320px;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .sk-topbar-search:focus-within {
    border-color: #7c3aed;
    box-shadow: 0 0 0 3px rgba(124,58,237,0.1);
  }
  .sk-topbar-search svg {
    width: 16px; height: 16px;
    color: #9ca3af;
    flex-shrink: 0;
  }
  .sk-topbar-search input {
    border: none;
    background: transparent;
    outline: none;
    font-size: 14px;
    font-family: 'DM Sans', sans-serif;
    color: #1e1b4b;
    width: 100%;
  }
  .sk-topbar-search input::placeholder { color: #9ca3af; }

  /* ── Right side ── */
  .sk-topbar-right {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 14px;
  }

  /* ── Bell ── */
  .sk-notif-btn {
    position: relative;
    width: 40px; height: 40px;
    border-radius: 50%;
    border: 1.5px solid #ede9fe;
    background: #fff;
    display: flex; align-items: center; justify-content: center;
    color: #6b7280;
    text-decoration: none;
    transition: border-color 0.2s, color 0.2s, box-shadow 0.2s;
  }
  .sk-notif-btn:hover {
    border-color: #7c3aed;
    color: #7c3aed;
    box-shadow: 0 0 0 3px rgba(124,58,237,0.1);
  }
  .sk-notif-btn svg { width: 18px; height: 18px; }

  .sk-notif-badge {
    position: absolute;
    top: -4px; right: -4px;
    min-width: 18px; height: 18px;
    background: #ef4444;
    color: #fff;
    font-size: 10px;
    font-weight: 700;
    font-family: 'DM Sans', sans-serif;
    border-radius: 50px;
    display: flex; align-items: center; justify-content: center;
    padding: 0 4px;
    border: 2px solid #fff;
  }

  /* ── Avatar ── */
  .sk-topbar-avatar {
    width: 38px; height: 38px;
    border-radius: 50%;
    overflow: hidden;
    border: 2.5px solid #7c3aed;
    display: block;
    flex-shrink: 0;
    transition: box-shadow 0.2s;
    text-decoration: none;
  }
  .sk-topbar-avatar:hover {
    box-shadow: 0 0 0 3px rgba(124,58,237,0.2);
  }
  .sk-topbar-avatar img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
  }
  .sk-avatar-fb {
    width: 100%; height: 100%;
    background: linear-gradient(135deg, #7c3aed, #4f46e5);
    color: #fff;
    font-size: 15px;
    font-weight: 700;
    font-family: 'DM Sans', sans-serif;
    display: flex; align-items: center; justify-content: center;
  }

  /* ── Responsive: tablet (sidebar collapsed to 72px) ── */
  @media (min-width: 768px) and (max-width: 1023px) {
    .sk-topbar { left: 72px; padding: 0 20px; }
    .sk-topbar-search { width: 240px; }
  }

  /* ── Responsive: mobile (sidebar hidden, topbar full width) ── */
  @media (max-width: 767px) {
    .sk-topbar {
      left: 0;
      padding: 0 16px;
    }
    .sk-topbar-search {
      width: 100%;
      max-width: 200px;
    }
  }
</style>

<script>
  (function() {
    var input = document.getElementById('skSearchInput');
    if (!input) return;
    var timer;
    input.addEventListener('input', function() {
      clearTimeout(timer);
      var q = this.value.trim();
      if (!q) return;
      timer = setTimeout(function() {
        window.location.href = '/explore?q=' + encodeURIComponent(q);
      }, 600);
    });
    input.addEventListener('keydown', function(e) {
      if (e.key === 'Enter') {
        var q = this.value.trim();
        if (q) window.location.href = '/explore?q=' + encodeURIComponent(q);
      }
    });
  })();
</script>

<script>
  // Live badge — poll every 30s so badge stays accurate without page reload
  (function() {
    function refreshBadge() {
      fetch('/swaps/requests/count', { credentials: 'same-origin' })
        .then(function(r){ return r.json(); })
        .then(function(data) {
          var badge = document.getElementById('skNotifBadge');
          if (!badge) return;
          if (data.count > 0) {
            badge.textContent = data.count > 9 ? '9+' : data.count;
            badge.style.display = 'flex';
          } else {
            badge.style.display = 'none';
          }
        })
        .catch(function(){});
    }
    refreshBadge();
    setInterval(refreshBadge, 30000);
  })();
</script>
