<div class="sidebar">
    <div class="sidebar-logo">
      <div class="logo-icon">
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M7 10L4 7L7 4" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M4 7H15C17.2 7 19 8.8 19 11" stroke="white" stroke-width="2.2" stroke-linecap="round"/>
          <path d="M17 14L20 17L17 20" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M20 17H9C6.8 17 5 15.2 5 13" stroke="white" stroke-width="2.2" stroke-linecap="round"/>
        </svg>
      </div>
      <div class="logo-text">
        <span>SkillSwap</span>
        <small>Admin Panel</small>
      </div>
    </div>

    <div class="nav-group">
      <div class="nav-section-label">Main</div>
      <a href="/admin/dashboard" class="<%= activePage === 'dashboard' ? 'active' : '' %>">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/></svg>
        Dashboard
      </a>
      <a href="/admin/users"  class="<%= activePage === 'users' ? 'active' : '' %>">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
        All Users
      </a>
      <a href="/admin/bannedUsers" class="<%= activePage === 'bannedUsers' ? 'active' : '' %>">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
        Banned Users
      </a>
    </div>

    <div class="nav-group">
      <div class="nav-section-label">Platform</div>
      <a href="/admin/swaps"  class="<%= activePage === 'swaps' ? 'active' : '' %>">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M7 16V4m0 0L3 8m4-4l4 4M17 8v12m0 0l4-4m-4 4l-4-4"/></svg>
        Skill Swaps
      </a>
      <a href="/admin/sessions"  class="<%= activePage === 'sessions' ? 'active' : '' %>">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        Sessions
      </a>
      <a href="/admin/reviews"   class="<%= activePage === 'reviews' ? 'active' : '' %>">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        Reviews
      </a>
    </div>

    <div class="sidebar-footer">
      <a href="/auth/logout">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4M16 17l5-5-5-5M21 12H9"/></svg>
        Logout
      </a>
    </div>
  </div>

  <style>
     .sidebar {
      width: 240px;
      min-height: 100vh;
      background: #ffffff;
      border-right: 1px solid #e5e0f5;
      position: fixed;
      top: 0; left: 0;
      display: flex;
      flex-direction: column;
      padding: 28px 20px;
      box-shadow: 2px 0 12px rgba(108, 99, 255, 0.06);
      z-index: 100;
    }

    .sidebar-logo {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 36px;
      padding-bottom: 24px;
      border-bottom: 1px solid #f0ebff;
    }

    .logo-icon {
      width: 38px; height: 38px;
      background: #6c63ff;
      border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }

    .logo-icon svg { width: 22px; height: 22px; }

    .logo-text span {
      display: block;
      font-size: 16px;
      font-weight: 700;
      color: #1a1340;
    }

    .logo-text small {
      font-size: 11px;
      font-weight: 400;
      color: #9b94c4;
    }

    .nav-section-label {
      font-size: 10px;
      font-weight: 600;
      color: #b0a8d8;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      margin-bottom: 8px;
      padding-left: 12px;
    }

    .nav-group { margin-bottom: 24px; }

    .sidebar a {
      display: flex;
      align-items: center;
      gap: 10px;
      color: #5a5280;
      text-decoration: none;
      padding: 10px 12px;
      border-radius: 10px;
      font-size: 14px;
      font-weight: 500;
      margin-bottom: 2px;
      transition: background 0.15s, color 0.15s;
    }

    .sidebar a svg { width: 18px; height: 18px; flex-shrink: 0; }
    .sidebar a:hover { background: #f3f0ff; color: #6c63ff; }
    .sidebar a.active { background: #f0ebff; color: #6c63ff; font-weight: 600; }

    .sidebar-footer {
      margin-top: auto;
      padding-top: 20px;
      border-top: 1px solid #f0ebff;
    }

    .sidebar-footer a { color: #e05252; }
    .sidebar-footer a:hover { background: #fff0f0; color: #c0392b; }
  </style>