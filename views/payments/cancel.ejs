<%- include('../partials/header') %>
<%- include('../partials/navbar') %>
<%- include('../partials/topbar') %>

<div class="payment-result-page">
  <div class="result-card cancel-card">
    <div class="result-icon">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <circle cx="12" cy="12" r="10"/>
        <line x1="15" y1="9" x2="9" y2="15"/>
        <line x1="9" y1="9" x2="15" y2="15"/>
      </svg>
    </div>

    <h1>Payment Cancelled</h1>
    <p class="result-subtitle">No worries — you haven't been charged. You can try again anytime.</p>

    <div class="result-actions">
      <a href="/dashboard" class="btn-primary">Back to Dashboard</a>
      <a href="/explore" class="btn-outline">Explore Skills</a>
    </div>
  </div>
</div>

<style>
  .payment-result-page {
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    background: var(--bg, #eeeaf8);
  }

  .result-card {
    background: white;
    border-radius: 20px;
    padding: 3rem 2.5rem;
    max-width: 480px;
    width: 100%;
    text-align: center;
    box-shadow: 0 8px 32px rgba(108, 99, 255, 0.12);
  }

  .result-icon {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.5rem;
  }

  .cancel-card .result-icon {
    background: #fff1f0;
    color: #ef4444;
  }

  .result-icon svg { width: 36px; height: 36px; }

  .result-card h1 {
    font-size: 1.6rem;
    font-weight: 700;
    color: #1a1a2e;
    margin-bottom: 0.5rem;
  }

  .result-subtitle { color: #666; margin-bottom: 2rem; }

  .result-actions { display: flex; flex-direction: column; gap: 0.75rem; }

  .btn-primary {
    background: var(--brand, #6c63ff);
    color: white;
    padding: 0.85rem 1.5rem;
    border-radius: 10px;
    text-decoration: none;
    font-weight: 600;
  }

  .btn-outline {
    border: 2px solid var(--brand, #6c63ff);
    color: var(--brand, #6c63ff);
    padding: 0.75rem 1.5rem;
    border-radius: 10px;
    text-decoration: none;
    font-weight: 600;
  }
</style>

<%- include('../partials/footer') %>