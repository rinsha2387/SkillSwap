<%- include('../partials/header') %>
<%- include('../partials/navbar') %>
<%- include('../partials/topbar') %>

<div class="confirm-page">
  <div class="confirm-card">

    <!-- Header -->
    <div class="confirm-header">
      <div class="lock-icon">🔒</div>
      <h1>Confirm Payment</h1>
      <p>Review your order before proceeding to payment</p>
    </div>

    <!-- Order Summary -->
    <div class="order-summary">
      <h2>Order Summary</h2>

      <div class="summary-item">
        <div class="item-left">
          <% if (payee.profilePic) { %>
            <img src="<%= payee.profilePic %>" alt="<%= payee.name %>" class="payee-avatar" />
          <% } else { %>
            <div class="avatar-placeholder"><%= payee.name.charAt(0).toUpperCase() %></div>
          <% } %>
          <div class="item-info">
            <span class="item-title"><%= sessionTitle %></span>
            <span class="item-sub">with <%= payee.name %></span>
          </div>
        </div>
        <span class="item-price">₹<%= amount %></span>
      </div>

      <div class="divider"></div>

      <div class="summary-row">
        <span>Subtotal</span>
        <span>₹<%= amount %></span>
      </div>
      <div class="summary-row">
        <span>Platform Fee</span>
        <span class="free-tag">FREE</span>
      </div>
      <div class="summary-row total-row">
        <span>Total</span>
        <strong>₹<%= amount %></strong>
      </div>
    </div>

    <!-- Payment Methods Info -->
    <div class="payment-methods">
      <p class="methods-label">Accepted payment methods</p>
      <div class="methods-list">
        <span class="method-badge">💳 Card</span>
        <span class="method-badge">📱 UPI</span>
        <span class="method-badge">🏦 NetBanking</span>
        <span class="method-badge">👛 Wallets</span>
      </div>
    </div>

    <!-- Pay Button -->
    <a href="/payment/checkout/<%= paymentType === 'paid_session' ? 'session' : 'group' %>/<%= referenceId %>"
       class="pay-btn">
      Pay ₹<%= amount %> Securely
    </a>

    <a href="javascript:history.back()" class="cancel-link">← Go Back</a>

    <!-- Security Note -->
    <p class="security-note">
      🔐 Payments are processed securely by Cashfree. SkillSwap never stores your card details.
    </p>

  </div>
</div>

<style>
  .confirm-page {
    min-height: 100vh;
    background: var(--bg, #eeeaf8);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1rem;
  }

  .confirm-card {
    background: white;
    border-radius: 20px;
    padding: 2.5rem 2rem;
    max-width: 480px;
    width: 100%;
    box-shadow: 0 8px 32px rgba(108, 99, 255, 0.12);
  }

  /* ── Header ── */
  .confirm-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .lock-icon {
    font-size: 2.2rem;
    margin-bottom: 0.75rem;
  }

  .confirm-header h1 {
    font-size: 1.6rem;
    font-weight: 700;
    color: #1a1a2e;
    margin-bottom: 0.3rem;
  }

  .confirm-header p {
    color: #888;
    font-size: 0.9rem;
  }

  /* ── Order Summary ── */
  .order-summary {
    background: #f8f6ff;
    border-radius: 14px;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .order-summary h2 {
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #888;
    margin-bottom: 1rem;
  }

  .summary-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }

  .item-left {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .payee-avatar,
  .avatar-placeholder {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    object-fit: cover;
  }

  .avatar-placeholder {
    background: #6c63ff;
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1.1rem;
  }

  .item-info {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .item-title {
    font-weight: 600;
    color: #1a1a2e;
    font-size: 0.95rem;
  }

  .item-sub {
    color: #888;
    font-size: 0.82rem;
  }

  .item-price {
    font-weight: 700;
    font-size: 1.1rem;
    color: #1a1a2e;
  }

  .divider {
    height: 1px;
    background: #ede9fc;
    margin: 1rem 0;
  }

  .summary-row {
    display: flex;
    justify-content: space-between;
    font-size: 0.88rem;
    color: #555;
    padding: 0.3rem 0;
  }

  .free-tag {
    color: #22c55e;
    font-weight: 600;
  }

  .total-row {
    font-size: 1rem;
    color: #1a1a2e;
    margin-top: 0.5rem;
    padding-top: 0.75rem;
    border-top: 1px solid #ede9fc;
  }

  /* ── Payment Methods ── */
  .payment-methods {
    margin-bottom: 1.5rem;
  }

  .methods-label {
    font-size: 0.8rem;
    color: #888;
    margin-bottom: 0.6rem;
  }

  .methods-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .method-badge {
    background: #f3f0ff;
    color: #6c63ff;
    padding: 0.3rem 0.75rem;
    border-radius: 99px;
    font-size: 0.78rem;
    font-weight: 600;
  }

  /* ── Pay Button ── */
  .pay-btn {
    display: block;
    width: 100%;
    background: #6c63ff;
    color: white;
    text-align: center;
    padding: 1rem;
    border-radius: 12px;
    font-size: 1rem;
    font-weight: 700;
    text-decoration: none;
    transition: opacity 0.2s, transform 0.1s;
    margin-bottom: 1rem;
  }

  .pay-btn:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }

  .cancel-link {
    display: block;
    text-align: center;
    color: #888;
    font-size: 0.88rem;
    text-decoration: none;
    margin-bottom: 1.25rem;
  }

  .cancel-link:hover { color: #555; }

  /* ── Security Note ── */
  .security-note {
    text-align: center;
    font-size: 0.78rem;
    color: #aaa;
    line-height: 1.5;
  }

  /* ── Mobile ── */
  @media (max-width: 480px) {
    .confirm-card {
      padding: 2rem 1.25rem;
      border-radius: 16px;
    }
  }
</style>

<%- include('../partials/footer') %>
