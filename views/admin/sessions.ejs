<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sessions - SkillSwap Admin</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <%- include('../partials/adminSidebar', { activePage: 'sessions' }) %>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Inter', Arial, sans-serif; background: #eeeaf8; min-height: 100vh; display: flex; }
    
    .main { margin-left: 240px; flex: 1; padding: 32px 28px; min-height: 100vh; }
    .topbar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 28px; }
    .topbar-left h1 { font-size: 22px; font-weight: 700; color: #1a1340; }
    .topbar-left p { font-size: 13px; color: #9b94c4; margin-top: 2px; }
    .admin-badge { display: flex; align-items: center; gap: 10px; background: white; border: 1px solid #e5e0f5; border-radius: 50px; padding: 6px 16px 6px 6px; }
    .admin-avatar { width: 32px; height: 32px; background: #6c63ff; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 700; color: white; }
    .admin-badge span { font-size: 13px; font-weight: 600; color: #1a1340; }
    .cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 18px; margin-bottom: 28px; }
    .card { background: white; border-radius: 16px; padding: 20px 22px; border: 1px solid #ede8ff; box-shadow: 0 2px 10px rgba(108,99,255,.06); }
    .card-icon { width: 42px; height: 42px; border-radius: 12px; display: flex; align-items: center; justify-content: center; margin-bottom: 14px; }
    .card-icon svg { width: 20px; height: 20px; fill: none; stroke-width: 2; }
    .card-icon.purple { background: #f0ebff; } .card-icon.purple svg { stroke: #6c63ff; }
    .card-icon.green  { background: #edfaf3; } .card-icon.green  svg { stroke: #22c55e; }
    .card-icon.amber  { background: #fffbeb; } .card-icon.amber  svg { stroke: #f59e0b; }
    .card-icon.red    { background: #fff0f0; } .card-icon.red    svg { stroke: #e05252; }
    .card-label { font-size: 11px; font-weight: 600; color: #9b94c4; text-transform: uppercase; letter-spacing: .06em; margin-bottom: 4px; }
    .card-value { font-size: 28px; font-weight: 700; color: #1a1340; }
    .table-card { background: white; border-radius: 16px; padding: 22px 24px; border: 1px solid #ede8ff; box-shadow: 0 2px 10px rgba(108,99,255,.06); }
    .table-topbar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 18px; flex-wrap: wrap; gap: 10px; }
    .table-topbar h3 { font-size: 15px; font-weight: 600; color: #1a1340; }
    .table-controls { display: flex; gap: 10px; flex-wrap: wrap; align-items: center; }
    .search-box { display: flex; align-items: center; gap: 8px; border: 1px solid #e5e0f5; border-radius: 10px; padding: 8px 14px; background: #faf9ff; }
    .search-box svg { width: 15px; height: 15px; stroke: #b0a8d8; fill: none; flex-shrink: 0; }
    .search-box input { border: none; outline: none; background: transparent; font-size: 13px; color: #1a1340; font-family: 'Inter', Arial, sans-serif; width: 180px; }
    .search-box input::placeholder { color: #b0a8d8; }
    .filter-tabs { display: flex; gap: 6px; }
    .ftab { padding: 6px 14px; font-size: 12px; font-weight: 500; border-radius: 50px; cursor: pointer; border: 1px solid #e5e0f5; background: transparent; color: #9b94c4; font-family: 'Inter', Arial, sans-serif; transition: all .15s; }
    .ftab:hover { background: #f3f0ff; color: #6c63ff; border-color: #c9c1f5; }
    .ftab.active { background: #6c63ff; color: white; border-color: #6c63ff; }
    table { width: 100%; border-collapse: collapse; font-size: 13px; }
    thead th { text-align: left; padding: 8px 12px; font-size: 11px; font-weight: 600; color: #b0a8d8; text-transform: uppercase; letter-spacing: .05em; border-bottom: 1px solid #f0ebff; }
    tbody td { padding: 12px; border-bottom: 1px solid #f9f7ff; color: #1a1340; vertical-align: middle; }
    tbody tr:last-child td { border-bottom: none; }
    tbody tr:hover td { background: #faf9ff; }
    .user-cell { display: flex; align-items: center; gap: 8px; }
    .u-avatar { width: 30px; height: 30px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 600; flex-shrink: 0; }
    .u-name { font-weight: 500; font-size: 13px; color: #1a1340; }
    .u-sub  { font-size: 11px; color: #9b94c4; }
    .badge { display: inline-flex; align-items: center; padding: 3px 10px; border-radius: 50px; font-size: 11px; font-weight: 600; }
    .badge-scheduled { background: #f0ebff; color: #6c63ff; }
    .badge-active    { background: #edfaf3; color: #16a34a; }
    .badge-ended     { background: #f9f7ff; color: #9b94c4; }
    .badge-cancelled { background: #fff0f0; color: #dc2626; }
    .badge-free      { background: #edfaf3; color: #16a34a; }
    .badge-paid      { background: #fffbeb; color: #d97706; }
    .live-dot { display: inline-block; width: 7px; height: 7px; border-radius: 50%; background: #22c55e; margin-right: 4px; animation: pulse 1.4s infinite; }
    @keyframes pulse { 0%,100%{opacity:1}50%{opacity:.4} }
    .empty-row td { text-align: center; padding: 36px; color: #b0a8d8; font-size: 13px; }
  </style>
</head>
<body>


<div class="main">
  <div class="topbar">
    <div class="topbar-left">
      <h1>Group Sessions</h1>
      <p>All live and scheduled sessions on the platform</p>
    </div>
    <div class="admin-badge"><div class="admin-avatar">A</div><span>Admin</span></div>
  </div>

  <div class="cards">
    <div class="card">
      <div class="card-icon purple"><svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></div>
      <div class="card-label">Total Sessions</div>
      <div class="card-value"><%= totalSessions || 0 %></div>
    </div>
    <div class="card">
      <div class="card-icon green"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div>
      <div class="card-label">Live Now</div>
      <div class="card-value"><%= liveSessions || 0 %></div>
    </div>
    <div class="card">
      <div class="card-icon amber"><svg viewBox="0 0 24 24"><path d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01"/></svg></div>
      <div class="card-label">Scheduled</div>
      <div class="card-value"><%= scheduledSessions || 0 %></div>
    </div>
    <div class="card">
      <div class="card-icon red"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></div>
      <div class="card-label">Ended</div>
      <div class="card-value"><%= endedSessions || 0 %></div>
    </div>
  </div>

  <div class="table-card">
    <div class="table-topbar">
      <h3>All Sessions</h3>
      <div class="table-controls">
        <div class="search-box">
          <svg viewBox="0 0 24 24" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <input id="searchInput" placeholder="Search sessions..."/>
        </div>
        <div class="filter-tabs">
          <button class="ftab active" onclick="filterSessions('all',this)">All</button>
          <button class="ftab" onclick="filterSessions('active',this)">Live</button>
          <button class="ftab" onclick="filterSessions('scheduled',this)">Scheduled</button>
          <button class="ftab" onclick="filterSessions('ended',this)">Ended</button>
          <button class="ftab" onclick="filterSessions('cancelled',this)">Cancelled</button>
        </div>
      </div>
    </div>

    <table>
      <thead>
        <tr>
          <th>Title</th>
          <th>Host</th>
          <th>Participants</th>
          <th>Scheduled</th>
          <th>Type</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody id="sessionsTable"></tbody>
    </table>
  </div>
</div>

<script>
  const sessionsData = <%- JSON.stringify(sessions || []) %>;
  let currentFilter = 'all';
  let searchTerm = '';

  const avatarColors = [
    { bg:'#f0ebff', tc:'#6c63ff' }, { bg:'#edfaf3', tc:'#16a34a' },
    { bg:'#fffbeb', tc:'#d97706' }, { bg:'#e0f2fe', tc:'#0284c7' },
    { bg:'#fce7f3', tc:'#be185d' }
  ];

  function badgeClass(status) {
    return { scheduled:'badge-scheduled', active:'badge-active', ended:'badge-ended', cancelled:'badge-cancelled' }[status] || 'badge-scheduled';
  }

  function renderTable() {
    const tbody = document.getElementById('sessionsTable');
    const filtered = sessionsData.filter(s => {
      const matchFilter = currentFilter === 'all' || s.status === currentFilter;
      const title = (s.title || '').toLowerCase();
      const host  = (s.host?.name || '').toLowerCase();
      return matchFilter && (title.includes(searchTerm) || host.includes(searchTerm));
    });

    if (!filtered.length) {
      tbody.innerHTML = '<tr class="empty-row"><td colspan="6">No sessions found</td></tr>';
      return;
    }

    tbody.innerHTML = filtered.map((s, i) => {
      const col      = avatarColors[i % avatarColors.length];
      const hostName = s.host?.name || 'Unknown';
      const hostInit = hostName.charAt(0).toUpperCase();
      const date     = s.scheduledAt ? new Date(s.scheduledAt).toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric' }) : '—';
      const time     = s.scheduledAt ? new Date(s.scheduledAt).toLocaleTimeString('en-IN', { hour:'2-digit', minute:'2-digit' }) : '';
      const pCount   = (s.participants || []).filter(p => p.paid || s.isFree).length;
      const isLive   = s.status === 'active';
      const typeBadge = s.isFree
        ? '<span class="badge badge-free">Free</span>'
        : `<span class="badge badge-paid">₹${s.price}</span>`;

      return `<tr>
        <td>
          <div class="u-name">${s.title || '—'}</div>
          <div class="u-sub">${s.skillTaught || ''} · ${s.level || ''}</div>
        </td>
        <td>
          <div class="user-cell">
            <div class="u-avatar" style="background:${col.bg};color:${col.tc}">${hostInit}</div>
            <div class="u-name">${hostName}</div>
          </div>
        </td>
        <td style="color:#5a5280">${pCount} / ${s.maxParticipants || '—'}</td>
        <td>
          <div class="u-name">${date}</div>
          <div class="u-sub">${time}</div>
        </td>
        <td>${typeBadge}</td>
        <td>
          <span class="badge ${badgeClass(s.status)}">
            ${isLive ? '<span class="live-dot"></span>' : ''}${s.status}
          </span>
        </td>
      </tr>`;
    }).join('');
  }

  function filterSessions(f, el) {
    currentFilter = f;
    document.querySelectorAll('.ftab').forEach(b => b.classList.remove('active'));
    el.classList.add('active');
    renderTable();
  }

  document.getElementById('searchInput').addEventListener('input', function() {
    searchTerm = this.value.toLowerCase();
    renderTable();
  });

  renderTable();
</script>
</body>
</html>
