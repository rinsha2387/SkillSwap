<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Reviews - SkillSwap Admin</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <%- include('../partials/adminSidebar', { activePage: 'reviews' }) %>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Inter', Arial, sans-serif; background: #eeeaf8; min-height: 100vh; display: flex; }
    
    .main { margin-left: 240px; flex: 1; padding: 32px 28px; min-height: 100vh; }
    .topbar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 28px; }
    .topbar-left h1 { font-size: 22px; font-weight: 700; color: #1a1340; }
    .topbar-left p { font-size: 13px; color: #9b94c4; margin-top: 2px; }
    .admin-badge { display: flex; align-items: center; gap: 10px; background: white; border: 1px solid #e5e0f5; border-radius: 50px; padding: 6px 16px 6px 6px; }
    .admin-avatar { width: 32px; height: 32px; background: #6c63ff; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 700; color: white; }
    .admin-badge span { font-size: 13px; font-weight: 600; color: #1a1340; }
    .cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 18px; margin-bottom: 28px; }
    .card { background: white; border-radius: 16px; padding: 20px 22px; border: 1px solid #ede8ff; box-shadow: 0 2px 10px rgba(108,99,255,.06); }
    .card-icon { width: 42px; height: 42px; border-radius: 12px; display: flex; align-items: center; justify-content: center; margin-bottom: 14px; }
    .card-icon svg { width: 20px; height: 20px; fill: none; stroke-width: 2; }
    .card-icon.purple { background: #f0ebff; } .card-icon.purple svg { stroke: #6c63ff; }
    .card-icon.amber  { background: #fffbeb; } .card-icon.amber  svg { stroke: #f59e0b; }
    .card-icon.green  { background: #edfaf3; } .card-icon.green  svg { stroke: #22c55e; }
    .card-icon.blue   { background: #e0f2fe; } .card-icon.blue   svg { stroke: #0284c7; }
    .card-label { font-size: 11px; font-weight: 600; color: #9b94c4; text-transform: uppercase; letter-spacing: .06em; margin-bottom: 4px; }
    .card-value { font-size: 28px; font-weight: 700; color: #1a1340; }
    .table-card { background: white; border-radius: 16px; padding: 22px 24px; border: 1px solid #ede8ff; box-shadow: 0 2px 10px rgba(108,99,255,.06); }
    .table-topbar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 18px; flex-wrap: wrap; gap: 10px; }
    .table-topbar h3 { font-size: 15px; font-weight: 600; color: #1a1340; }
    .table-controls { display: flex; gap: 10px; flex-wrap: wrap; align-items: center; }
    .search-box { display: flex; align-items: center; gap: 8px; border: 1px solid #e5e0f5; border-radius: 10px; padding: 8px 14px; background: #faf9ff; }
    .search-box svg { width: 15px; height: 15px; stroke: #b0a8d8; fill: none; flex-shrink: 0; }
    .search-box input { border: none; outline: none; background: transparent; font-size: 13px; color: #1a1340; font-family: 'Inter', Arial, sans-serif; width: 180px; }
    .search-box input::placeholder { color: #b0a8d8; }
    .filter-tabs { display: flex; gap: 6px; }
    .ftab { padding: 6px 14px; font-size: 12px; font-weight: 500; border-radius: 50px; cursor: pointer; border: 1px solid #e5e0f5; background: transparent; color: #9b94c4; font-family: 'Inter', Arial, sans-serif; transition: all .15s; }
    .ftab:hover { background: #f3f0ff; color: #6c63ff; border-color: #c9c1f5; }
    .ftab.active { background: #6c63ff; color: white; border-color: #6c63ff; }
    table { width: 100%; border-collapse: collapse; font-size: 13px; }
    thead th { text-align: left; padding: 8px 12px; font-size: 11px; font-weight: 600; color: #b0a8d8; text-transform: uppercase; letter-spacing: .05em; border-bottom: 1px solid #f0ebff; }
    tbody td { padding: 12px; border-bottom: 1px solid #f9f7ff; color: #1a1340; vertical-align: middle; }
    tbody tr:last-child td { border-bottom: none; }
    tbody tr:hover td { background: #faf9ff; }
    .user-cell { display: flex; align-items: center; gap: 8px; }
    .u-avatar { width: 30px; height: 30px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 600; flex-shrink: 0; }
    .u-name { font-weight: 500; font-size: 13px; color: #1a1340; }
    .u-sub  { font-size: 11px; color: #9b94c4; }
    .badge { display: inline-flex; align-items: center; padding: 3px 10px; border-radius: 50px; font-size: 11px; font-weight: 600; }
    .badge-swap    { background: #f0ebff; color: #6c63ff; }
    .badge-session { background: #e0f2fe; color: #0284c7; }
    .stars-row { display: flex; gap: 2px; }
    .star { font-size: 13px; }
    .star.filled { color: #f59e0b; }
    .star.empty  { color: #e5e7eb; }
    .review-comment { font-size: 12px; color: #5a5280; max-width: 220px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .act-btn { padding: 5px 10px; font-size: 11px; font-weight: 500; border-radius: 8px; cursor: pointer; border: 1px solid #fca5a5; background: transparent; color: #dc2626; font-family: 'Inter', Arial, sans-serif; transition: all .15s; }
    .act-btn:hover { background: #fff0f0; }
    .empty-row td { text-align: center; padding: 36px; color: #b0a8d8; font-size: 13px; }
  </style>
</head>
<body>


<div class="main">
  <div class="topbar">
    <div class="topbar-left">
      <h1>Reviews</h1>
      <p>All user reviews across swaps and sessions</p>
    </div>
    <div class="admin-badge"><div class="admin-avatar">A</div><span>Admin</span></div>
  </div>

  <div class="cards">
    <div class="card">
      <div class="card-icon purple"><svg viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg></div>
      <div class="card-label">Total Reviews</div>
      <div class="card-value"><%= totalReviews || 0 %></div>
    </div>
    <div class="card">
      <div class="card-icon amber"><svg viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg></div>
      <div class="card-label">Avg Rating</div>
      <div class="card-value"><%= avgRating || '0.0' %></div>
    </div>
    <div class="card">
      <div class="card-icon green"><svg viewBox="0 0 24 24"><path d="M7 16V4m0 0L3 8m4-4l4 4M17 8v12m0 0l4-4m-4 4l-4-4"/></svg></div>
      <div class="card-label">Swap Reviews</div>
      <div class="card-value"><%= swapReviews || 0 %></div>
    </div>
    <div class="card">
      <div class="card-icon blue"><svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></div>
      <div class="card-label">Session Reviews</div>
      <div class="card-value"><%= sessionReviews || 0 %></div>
    </div>
  </div>

  <div class="table-card">
    <div class="table-topbar">
      <h3>All Reviews</h3>
      <div class="table-controls">
        <div class="search-box">
          <svg viewBox="0 0 24 24" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <input id="searchInput" placeholder="Search by name or comment..."/>
        </div>
        <div class="filter-tabs">
          <button class="ftab active" onclick="filterReviews('all',this)">All</button>
          <button class="ftab" onclick="filterReviews('swap',this)">Swaps</button>
          <button class="ftab" onclick="filterReviews('session',this)">Sessions</button>
          <button class="ftab" onclick="filterReviews('5',this)">★ 5</button>
          <button class="ftab" onclick="filterReviews('low',this)">Low Rated</button>
        </div>
      </div>
    </div>

    <table>
      <thead>
        <tr>
          <th>Reviewer</th>
          <th>Reviewee</th>
          <th>Rating</th>
          <th>Comment</th>
          <th>Type</th>
          <th>Date</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody id="reviewsTable"></tbody>
    </table>
  </div>
</div>

<script>
  const reviewsData = <%- JSON.stringify(reviews || []) %>;
  let currentFilter = 'all';
  let searchTerm = '';

  const avatarColors = [
    { bg:'#f0ebff', tc:'#6c63ff' }, { bg:'#edfaf3', tc:'#16a34a' },
    { bg:'#fffbeb', tc:'#d97706' }, { bg:'#e0f2fe', tc:'#0284c7' },
    { bg:'#fce7f3', tc:'#be185d' }
  ];

  function starsHtml(rating) {
    let html = '';
    for (let i = 1; i <= 5; i++) {
      html += `<span class="star ${i <= rating ? 'filled' : 'empty'}">★</span>`;
    }
    return `<div class="stars-row">${html}</div>`;
  }

  function renderTable() {
    const tbody = document.getElementById('reviewsTable');
    const filtered = reviewsData.filter(r => {
      const type = r.swap ? 'swap' : 'session';
      let matchFilter = true;
      if (currentFilter === 'swap')    matchFilter = type === 'swap';
      if (currentFilter === 'session') matchFilter = type === 'session';
      if (currentFilter === '5')       matchFilter = r.rating === 5;
      if (currentFilter === 'low')     matchFilter = r.rating <= 2;

      const rName  = (r.reviewer?.name  || '').toLowerCase();
      const rcName = (r.reviewee?.name  || '').toLowerCase();
      const comment = (r.comment || '').toLowerCase();
      return matchFilter && (rName.includes(searchTerm) || rcName.includes(searchTerm) || comment.includes(searchTerm));
    });

    if (!filtered.length) {
      tbody.innerHTML = '<tr class="empty-row"><td colspan="7">No reviews found</td></tr>';
      return;
    }

    tbody.innerHTML = filtered.map((r, i) => {
      const col   = avatarColors[i % avatarColors.length];
      const col2  = avatarColors[(i + 2) % avatarColors.length];
      const rName  = r.reviewer?.name  || 'Unknown';
      const rcName = r.reviewee?.name  || 'Unknown';
      const rInit  = rName.charAt(0).toUpperCase();
      const rcInit = rcName.charAt(0).toUpperCase();
      const type   = r.swap ? 'swap' : 'session';
      const date   = r.createdAt ? new Date(r.createdAt).toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric' }) : '—';
      const comment = r.comment || '—';

      return `<tr>
        <td>
          <div class="user-cell">
            <div class="u-avatar" style="background:${col.bg};color:${col.tc}">${rInit}</div>
            <div class="u-name">${rName}</div>
          </div>
        </td>
        <td>
          <div class="user-cell">
            <div class="u-avatar" style="background:${col2.bg};color:${col2.tc}">${rcInit}</div>
            <div class="u-name">${rcName}</div>
          </div>
        </td>
        <td>${starsHtml(r.rating)}</td>
        <td><div class="review-comment" title="${comment}">${comment}</div></td>
        <td><span class="badge badge-${type}">${type}</span></td>
        <td style="color:#9b94c4">${date}</td>
        <td>
          <button class="act-btn" onclick="deleteReview('${r._id}', this)">Delete</button>
        </td>
      </tr>`;
    }).join('');
  }

  function filterReviews(f, el) {
    currentFilter = f;
    document.querySelectorAll('.ftab').forEach(b => b.classList.remove('active'));
    el.classList.add('active');
    renderTable();
  }

  async function deleteReview(id, btn) {
  if (!confirm('Delete this review? This cannot be undone.')) return;
  try {
    const res = await fetch(`/admin/reviews/${id}/delete`, { method: 'POST' });

    
    console.log('Status:', res.status);
    const text = await res.text();
    console.log('Response:', text);

    let data;
    try { data = JSON.parse(text); }
    catch { alert('Server returned non-JSON: ' + text); return; }

    if (data.success) {
      const idx = reviewsData.findIndex(r => String(r._id) === String(id));
      if (idx > -1) reviewsData.splice(idx, 1);
      renderTable();
    } else {
      alert('Failed to delete review: ' + (data.message || 'Unknown error'));
    }
  } catch (err) {
    console.error('Fetch error:', err);
    alert('Network error: ' + err.message);
  }
}
  document.getElementById('searchInput').addEventListener('input', function() {
    searchTerm = this.value.toLowerCase();
    renderTable();
  });

  renderTable();
</script>
</body>
</html>
