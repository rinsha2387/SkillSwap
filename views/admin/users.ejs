<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>All Users - SkillSwap Admin</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <%- include('../partials/adminSidebar', { activePage: 'users' }) %>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Inter', Arial, sans-serif;
      background: #eeeaf8;
      min-height: 100vh;
      display: flex;
    }

    
    /* ── Main ── */
    .main {
      margin-left: 240px;
      flex: 1;
      padding: 32px 28px;
      min-height: 100vh;
    }

    /* ── Topbar ── */
    .topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 28px;
    }

    .topbar-left h1 {
      font-size: 22px;
      font-weight: 700;
      color: #1a1340;
    }

    .topbar-left p {
      font-size: 13px;
      color: #9b94c4;
      margin-top: 2px;
    }

    .admin-badge {
      display: flex;
      align-items: center;
      gap: 10px;
      background: white;
      border: 1px solid #e5e0f5;
      border-radius: 50px;
      padding: 6px 16px 6px 6px;
    }

    .admin-avatar {
      width: 32px; height: 32px;
      background: #6c63ff;
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 12px; font-weight: 700; color: white;
    }

    .admin-badge span {
      font-size: 13px;
      font-weight: 600;
      color: #1a1340;
    }

    /* ── Stats row ── */
    .stats-row {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
      margin-bottom: 24px;
    }

    .stat-card {
      background: white;
      border-radius: 14px;
      padding: 18px 20px;
      border: 1px solid #ede8ff;
      box-shadow: 0 2px 10px rgba(108,99,255,0.06);
      display: flex;
      align-items: center;
      gap: 14px;
    }

    .stat-icon {
      width: 40px; height: 40px;
      border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }

    .stat-icon svg { width: 20px; height: 20px; fill: none; stroke-width: 2; }
    .stat-icon.purple { background: #f0ebff; }
    .stat-icon.purple svg { stroke: #6c63ff; }
    .stat-icon.green  { background: #edfaf3; }
    .stat-icon.green  svg { stroke: #22c55e; }
    .stat-icon.red    { background: #fff0f0; }
    .stat-icon.red    svg { stroke: #e05252; }

    .stat-info p {
      font-size: 11px;
      font-weight: 600;
      color: #9b94c4;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .stat-info h2 {
      font-size: 24px;
      font-weight: 700;
      color: #1a1340;
      margin-top: 2px;
    }

    /* ── Table Card ── */
    .table-card {
      background: white;
      border-radius: 16px;
      padding: 22px 24px;
      border: 1px solid #ede8ff;
      box-shadow: 0 2px 10px rgba(108, 99, 255, 0.06);
    }

    .table-topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 18px;
      flex-wrap: wrap;
      gap: 12px;
    }

    .table-topbar h3 {
      font-size: 15px;
      font-weight: 600;
      color: #1a1340;
    }

    .table-controls {
      display: flex;
      gap: 10px;
      align-items: center;
      flex-wrap: wrap;
    }

    .search-box {
      display: flex;
      align-items: center;
      gap: 8px;
      border: 1px solid #e5e0f5;
      border-radius: 10px;
      padding: 8px 14px;
      background: #faf9ff;
    }

    .search-box svg { width: 15px; height: 15px; stroke: #b0a8d8; fill: none; flex-shrink: 0; }

    .search-box input {
      border: none; outline: none;
      background: transparent;
      font-size: 13px;
      color: #1a1340;
      font-family: 'Inter', Arial, sans-serif;
      width: 200px;
    }

    .search-box input::placeholder { color: #b0a8d8; }

    .filter-tabs { display: flex; gap: 6px; }

    .ftab {
      padding: 6px 14px;
      font-size: 12px;
      font-weight: 500;
      border-radius: 50px;
      cursor: pointer;
      border: 1px solid #e5e0f5;
      background: transparent;
      color: #9b94c4;
      font-family: 'Inter', Arial, sans-serif;
      transition: all 0.15s;
    }

    .ftab:hover  { background: #f3f0ff; color: #6c63ff; border-color: #c9c1f5; }
    .ftab.active { background: #6c63ff; color: white; border-color: #6c63ff; }

    /* ── Table ── */
    table { width: 100%; border-collapse: collapse; font-size: 13px; }

    thead th {
      text-align: left;
      padding: 8px 12px;
      font-size: 11px;
      font-weight: 600;
      color: #b0a8d8;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      border-bottom: 1px solid #f0ebff;
    }

    tbody td {
      padding: 13px 12px;
      border-bottom: 1px solid #f9f7ff;
      color: #1a1340;
      vertical-align: middle;
    }

    tbody tr:last-child td { border-bottom: none; }
    tbody tr:hover td { background: #faf9ff; }

    .user-cell { display: flex; align-items: center; gap: 10px; }

    .u-avatar {
      width: 36px; height: 36px;
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 13px; font-weight: 600;
      flex-shrink: 0;
    }

    .u-name  { font-weight: 500; font-size: 13px; color: #1a1340; }
    .u-email { font-size: 12px; color: #9b94c4; }

    .role-badge {
      display: inline-flex;
      align-items: center;
      padding: 3px 10px;
      border-radius: 50px;
      font-size: 11px;
      font-weight: 600;
      background: #f0ebff;
      color: #6c63ff;
    }

    .role-badge.admin { background: #fff3e0; color: #e65100; }

    .status-badge {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      padding: 3px 10px;
      border-radius: 50px;
      font-size: 11px;
      font-weight: 600;
    }

    .status-badge.active { background: #edfaf3; color: #16a34a; }
    .status-badge.banned { background: #fff0f0; color: #dc2626; }

    .status-dot {
      width: 6px; height: 6px;
      border-radius: 50%;
    }

    .active .status-dot { background: #16a34a; }
    .banned .status-dot { background: #dc2626; }

    .action-btns { display: flex; gap: 6px; align-items: center; }

    .act-btn {
      padding: 5px 12px;
      font-size: 11px;
      font-weight: 500;
      border-radius: 8px;
      cursor: pointer;
      border: 1px solid #e5e0f5;
      background: transparent;
      color: #5a5280;
      font-family: 'Inter', Arial, sans-serif;
      text-decoration: none;
      display: inline-flex; align-items: center; gap: 4px;
      transition: all 0.15s;
    }

    .act-btn:hover { background: #f3f0ff; color: #6c63ff; border-color: #c9c1f5; }

    .act-btn.ban   { color: #dc2626; border-color: #fca5a5; }
    .act-btn.ban:hover { background: #fff0f0; }

    .act-btn.unban { color: #16a34a; border-color: #86efac; }
    .act-btn.unban:hover { background: #edfaf3; }

    .act-btn.view  { color: #6c63ff; border-color: #c9c1f5; }
    .act-btn.view:hover { background: #f0ebff; }

    .blocked-text {
      font-size: 12px;
      color: #b0a8d8;
      font-style: italic;
    }

    .empty-row td {
      text-align: center;
      padding: 48px;
      color: #b0a8d8;
      font-size: 13px;
    }

    /* ── Pagination ── */
    .pagination {
      display: flex;
      justify-content: flex-end;
      align-items: center;
      gap: 6px;
      margin-top: 20px;
    }

    .page-info {
      font-size: 12px;
      color: #9b94c4;
      margin-right: 8px;
    }

    .page-btn {
      width: 32px; height: 32px;
      display: flex; align-items: center; justify-content: center;
      border-radius: 8px;
      border: 1px solid #e5e0f5;
      background: white;
      cursor: pointer;
      font-size: 13px;
      font-weight: 500;
      color: #5a5280;
      font-family: 'Inter', Arial, sans-serif;
      transition: all 0.15s;
    }

    .page-btn:hover  { background: #f3f0ff; color: #6c63ff; border-color: #c9c1f5; }
    .page-btn.active { background: #6c63ff; color: white; border-color: #6c63ff; }

    @media (max-width: 900px) {
      .stats-row { grid-template-columns: 1fr 1fr; }
    }
  </style>
</head>
<body>

  
  <!-- ── Main ── -->
  <div class="main">

    <!-- Topbar -->
    <div class="topbar">
      <div class="topbar-left">
        <h1>All Users</h1>
        <p>Manage and monitor all registered users</p>
      </div>
      <div class="admin-badge">
        <div class="admin-avatar">A</div>
        <span>Admin</span>
      </div>
    </div>

    <!-- Stats -->
    <div class="stats-row">
      <div class="stat-card">
        <div class="stat-icon purple">
          <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
        </div>
        <div class="stat-info">
          <p>Total Users</p>
          <h2><%= users.length %></h2>
        </div>
      </div>

     

      <div class="stat-card">
        <div class="stat-icon red">
          <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
        </div>
        <div class="stat-info">
          <p>Banned Users</p>
          <h2><%= users.filter(u => u.isBanned).length %></h2>
        </div>
      </div>
    </div>

    <!-- Table Card -->
    <div class="table-card">
      <div class="table-topbar">
        <h3>User List</h3>
        <div class="table-controls">
          <div class="search-box">
            <svg viewBox="0 0 24 24" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input id="searchInput" placeholder="Search by name or email..." />
          </div>
          <div class="filter-tabs">
            <button class="ftab active" onclick="filterTable('all', this)">All</button>
            <button class="ftab" onclick="filterTable('active', this)">Active</button>
            <button class="ftab" onclick="filterTable('banned', this)">Banned</button>
          </div>
        </div>
      </div>

      <table id="usersTable">
        <thead>
          <tr>
            <th>User</th>
            <th>Role</th>
            <th>Status</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% const avatarColors = [
            { bg:'#f0ebff', tc:'#6c63ff' },
            { bg:'#edfaf3', tc:'#16a34a' },
            { bg:'#fff0f0', tc:'#dc2626' },
            { bg:'#fffbeb', tc:'#d97706' },
            { bg:'#e0f2fe', tc:'#0369a1' },
            { bg:'#fce7f3', tc:'#be185d' }
          ]; %>

          <% users.forEach((user, i) => {
            const col = avatarColors[i % avatarColors.length];
            const initials = (user.name || 'U').split(' ').map(x => x[0]).join('').toUpperCase().slice(0,2);
            const statusClass = user.isBanned ? 'banned' : 'active';
            const statusText  = user.isBanned ? 'Banned' : 'Active';
          %>
            <tr data-status="<%= statusClass %>"
                data-name="<%= (user.name || '').toLowerCase() %>"
                data-email="<%= (user.email || '').toLowerCase() %>">

              <td>
                <div class="user-cell">
                  <div class="u-avatar" style="background: <%= col?.bg || '#333' %>; color: <%= col?.tc || '#fff' %>;">
                    <%= initials %>
                  </div>
                  <div>
                    <div class="u-name"><%= user.name || 'Unknown' %></div>
                    <div class="u-email"><%= user.email %></div>
                  </div>
                </div>
              </td>

              <td>
                <span class="role-badge <%= user.role === 'admin' ? 'admin' : '' %>">
                  <%= user.role || 'user' %>
                </span>
              </td>

              <td>
                <span class="status-badge <%= statusClass %>">
                  <span class="status-dot"></span>
                  <%= statusText %>
                </span>
              </td>

              <td>
                <div class="action-btns">
                  <% if (!user.isBanned) { %>
                    <button onclick="handleBan('<%= user._id %>', 'ban', this)" class="act-btn ban">⊘ Ban</button>
                  <% } else { %>
                    <button onclick="handleBan('<%= user._id %>', 'unban', this)" class="act-btn unban">✓ Unban</button>
                  <% } %>
                  <a href="/admin/users/<%= user._id %>" class="act-btn view">👁 View</a>
                </div>
              </td>

            </tr>
          <% }) %>
        </tbody>
      </table>

      <!-- Pagination info -->
      <div class="pagination">
        <span class="page-info" id="pageInfo"></span>
      </div>
    </div>

  </div><!-- /.main -->

  <script>
    /* ── Search & Filter ── */
    let currentFilter = 'all';
    let searchTerm    = '';

    function applyFilters() {
      const rows = document.querySelectorAll('#usersTable tbody tr');
      let visible = 0;

      rows.forEach(row => {
        const status = row.dataset.status;
        const name   = row.dataset.name  || '';
        const email  = row.dataset.email || '';

        const matchFilter = currentFilter === 'all' || status === currentFilter;
        const matchSearch = name.includes(searchTerm) || email.includes(searchTerm);

        const show = matchFilter && matchSearch;
        row.style.display = show ? '' : 'none';
        if (show) visible++;
      });

      // Show empty state if no results
      const tbody = document.querySelector('#usersTable tbody');
      const existingEmpty = document.getElementById('emptyRow');
      if (visible === 0) {
        if (!existingEmpty) {
          const tr = document.createElement('tr');
          tr.id = 'emptyRow';
          tr.innerHTML = '<td colspan="4" style="text-align:center;padding:48px;color:#b0a8d8;font-size:13px;">No users found</td>';
          tbody.appendChild(tr);
        }
      } else {
        if (existingEmpty) existingEmpty.remove();
      }

      document.getElementById('pageInfo').textContent =
        `Showing ${visible} of ${rows.length} users`;
    }

    function filterTable(f, el) {
      currentFilter = f;
      document.querySelectorAll('.ftab').forEach(b => b.classList.remove('active'));
      el.classList.add('active');
      applyFilters();
    }

async function handleBan(userId, action, btn) {
      if (!confirm(`Are you sure you want to ${action} this user?`)) return;
      try {
        const res  = await fetch(`/admin/users/${userId}/${action}`, { method: 'POST' });
        const data = await res.json();
        if (data.success) {
          const row = btn.closest('tr');
          const isBanned = action === 'ban';

          // Update row data-status for filter to work
          row.dataset.status = isBanned ? 'banned' : 'active';

          // Update status badge
          const badge = row.querySelector('.status-badge');
          badge.className = `status-badge ${isBanned ? 'banned' : 'active'}`;
          badge.innerHTML = `<span class="status-dot"></span> ${isBanned ? 'Banned' : 'Active'}`;

          // Swap the button
          btn.className = `act-btn ${isBanned ? 'unban' : 'ban'}`;
          btn.textContent = isBanned ? '✓ Unban' : '⊘ Ban';
          btn.setAttribute('onclick', `handleBan('${userId}', '${isBanned ? 'unban' : 'ban'}', this)`);

          // Update stat cards
          const activeEl = document.querySelector('.stat-icon.green + .stat-info h2');
          const bannedEl = document.querySelector('.stat-icon.red + .stat-info h2');
          if (activeEl && bannedEl) {
            activeEl.textContent = isBanned
              ? parseInt(activeEl.textContent) - 1
              : parseInt(activeEl.textContent) + 1;
            bannedEl.textContent = isBanned
              ? parseInt(bannedEl.textContent) + 1
              : parseInt(bannedEl.textContent) - 1;
          }

          applyFilters();
        } else {
          alert('Action failed: ' + (data.message || 'Unknown error'));
        }
      } catch {
        alert('Network error. Please try again.');
      }
    }

    document.getElementById('searchInput').addEventListener('input', function() {
      searchTerm = this.value.toLowerCase();
      applyFilters();
    });

    // init count
    applyFilters();
  </script>
</body>
</html>
