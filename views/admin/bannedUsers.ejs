<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Banned Users - SkillSwap Admin</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <%- include('../partials/adminSidebar', { activePage: 'bannedUsers' }) %>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Inter', Arial, sans-serif;
      background: #eeeaf8;
      min-height: 100vh;
      display: flex;
    }

    
    /* ── Main ── */
    .main {
      margin-left: 240px;
      flex: 1;
      padding: 32px 28px;
      min-height: 100vh;
    }

    /* ── Topbar ── */
    .topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 28px;
    }

    .topbar-left h1 {
      font-size: 22px;
      font-weight: 700;
      color: #1a1340;
    }

    .topbar-left p {
      font-size: 13px;
      color: #9b94c4;
      margin-top: 2px;
    }

    .admin-badge {
      display: flex;
      align-items: center;
      gap: 10px;
      background: white;
      border: 1px solid #e5e0f5;
      border-radius: 50px;
      padding: 6px 16px 6px 6px;
    }

    .admin-avatar {
      width: 32px; height: 32px;
      background: #6c63ff;
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 12px; font-weight: 700; color: white;
    }

    .admin-badge span { font-size: 13px; font-weight: 600; color: #1a1340; }

    /* ── Alert Banner ── */
    .alert-banner {
      display: flex;
      align-items: center;
      gap: 12px;
      background: #fff0f0;
      border: 1px solid #fca5a5;
      border-radius: 12px;
      padding: 14px 18px;
      margin-bottom: 24px;
    }

    .alert-banner svg { width: 20px; height: 20px; stroke: #dc2626; fill: none; flex-shrink: 0; }

    .alert-banner p {
      font-size: 13px;
      color: #7f1d1d;
      font-weight: 500;
    }

    .alert-banner span {
      font-size: 13px;
      color: #dc2626;
      font-weight: 700;
    }

    /* ── Stat Cards ── */
    .stats-row {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
      margin-bottom: 24px;
    }

    .stat-card {
      background: white;
      border-radius: 14px;
      padding: 18px 20px;
      border: 1px solid #ede8ff;
      box-shadow: 0 2px 10px rgba(108,99,255,0.06);
      display: flex;
      align-items: center;
      gap: 14px;
    }

    .stat-icon {
      width: 40px; height: 40px;
      border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }

    .stat-icon svg { width: 20px; height: 20px; fill: none; stroke-width: 2; }
    .stat-icon.red    { background: #fff0f0; }
    .stat-icon.red    svg { stroke: #e05252; }
    .stat-icon.amber  { background: #fffbeb; }
    .stat-icon.amber  svg { stroke: #f59e0b; }
    .stat-icon.purple { background: #f0ebff; }
    .stat-icon.purple svg { stroke: #6c63ff; }

    .stat-info p {
      font-size: 11px;
      font-weight: 600;
      color: #9b94c4;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .stat-info h2 {
      font-size: 24px;
      font-weight: 700;
      color: #1a1340;
      margin-top: 2px;
    }

    /* ── Table Card ── */
    .table-card {
      background: white;
      border-radius: 16px;
      padding: 22px 24px;
      border: 1px solid #ede8ff;
      box-shadow: 0 2px 10px rgba(108, 99, 255, 0.06);
    }

    .table-topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 18px;
      flex-wrap: wrap;
      gap: 12px;
    }

    .table-topbar-left h3 {
      font-size: 15px;
      font-weight: 600;
      color: #1a1340;
    }

    .table-topbar-left p {
      font-size: 12px;
      color: #9b94c4;
      margin-top: 2px;
    }

    .search-box {
      display: flex;
      align-items: center;
      gap: 8px;
      border: 1px solid #e5e0f5;
      border-radius: 10px;
      padding: 8px 14px;
      background: #faf9ff;
    }

    .search-box svg { width: 15px; height: 15px; stroke: #b0a8d8; fill: none; flex-shrink: 0; }

    .search-box input {
      border: none; outline: none;
      background: transparent;
      font-size: 13px;
      color: #1a1340;
      font-family: 'Inter', Arial, sans-serif;
      width: 200px;
    }

    .search-box input::placeholder { color: #b0a8d8; }

    /* ── Table ── */
    table { width: 100%; border-collapse: collapse; font-size: 13px; }

    thead th {
      text-align: left;
      padding: 8px 12px;
      font-size: 11px;
      font-weight: 600;
      color: #b0a8d8;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      border-bottom: 1px solid #f0ebff;
    }

    tbody td {
      padding: 13px 12px;
      border-bottom: 1px solid #f9f7ff;
      color: #1a1340;
      vertical-align: middle;
    }

    tbody tr:last-child td { border-bottom: none; }
    tbody tr:hover td { background: #faf9ff; }

    .user-cell { display: flex; align-items: center; gap: 10px; }

    .u-avatar {
      width: 36px; height: 36px;
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 13px; font-weight: 600;
      flex-shrink: 0;
    }

    .u-name  { font-weight: 500; font-size: 13px; color: #1a1340; }
    .u-email { font-size: 12px; color: #9b94c4; }

    .role-badge {
      display: inline-flex;
      align-items: center;
      padding: 3px 10px;
      border-radius: 50px;
      font-size: 11px;
      font-weight: 600;
      background: #f0ebff;
      color: #6c63ff;
    }

    .role-badge.admin { background: #fff3e0; color: #e65100; }

    .banned-badge {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      padding: 3px 10px;
      border-radius: 50px;
      font-size: 11px;
      font-weight: 600;
      background: #fff0f0;
      color: #dc2626;
    }

    .banned-dot {
      width: 6px; height: 6px;
      border-radius: 50%;
      background: #dc2626;
    }

    .reason-text {
      font-size: 12px;
      color: #9b94c4;
      max-width: 180px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .action-btns { display: flex; gap: 6px; align-items: center; }

    .act-btn {
      padding: 5px 12px;
      font-size: 11px;
      font-weight: 500;
      border-radius: 8px;
      cursor: pointer;
      border: 1px solid #e5e0f5;
      background: transparent;
      color: #5a5280;
      font-family: 'Inter', Arial, sans-serif;
      text-decoration: none;
      display: inline-flex; align-items: center; gap: 4px;
      transition: all 0.15s;
    }

    .act-btn:hover  { background: #f3f0ff; color: #6c63ff; border-color: #c9c1f5; }
    .act-btn.unban  { color: #16a34a; border-color: #86efac; }
    .act-btn.unban:hover { background: #edfaf3; }
    .act-btn.view   { color: #6c63ff; border-color: #c9c1f5; }
    .act-btn.view:hover  { background: #f0ebff; }

    /* ── Empty State ── */
    .empty-state {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 60px 20px;
      text-align: center;
    }

    .empty-icon {
      width: 64px; height: 64px;
      background: #f0ebff;
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      margin-bottom: 16px;
    }

    .empty-icon svg { width: 28px; height: 28px; stroke: #6c63ff; fill: none; stroke-width: 1.5; }

    .empty-state h3 { font-size: 15px; font-weight: 600; color: #1a1340; margin-bottom: 6px; }
    .empty-state p  { font-size: 13px; color: #9b94c4; }

    /* ── Footer info ── */
    .table-footer {
      display: flex;
      justify-content: flex-end;
      margin-top: 16px;
    }

    .page-info { font-size: 12px; color: #9b94c4; }

    @media (max-width: 900px) {
      .stats-row { grid-template-columns: 1fr 1fr; }
    }
  </style>
</head>
<body>

 

  <!-- ── Main ── -->
  <div class="main">

    <!-- Topbar -->
    <div class="topbar">
      <div class="topbar-left">
        <h1>Banned Users</h1>
        <p>Review and manage all banned accounts</p>
      </div>
      <div class="admin-badge">
        <div class="admin-avatar">A</div>
        <span>Admin</span>
      </div>
    </div>

    <!-- Alert Banner -->
    <% const bannedList = users.filter(u => u.isBanned); %>
    <% if (bannedList.length > 0) { %>
    <div class="alert-banner">
      <svg viewBox="0 0 24 24" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      <p>There are currently <span><%= bannedList.length %> banned account(s)</span> on SkillSwap. Review them below and unban if needed.</p>
    </div>
    <% } %>

    <!-- Stats -->
    <div class="stats-row">
      <div class="stat-card">
        <div class="stat-icon red">
          <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
        </div>
        <div class="stat-info">
          <p>Total Banned</p>
          <h2><%= bannedList.length %></h2>
        </div>
      </div>

      

      <div class="stat-card">
        <div class="stat-icon purple">
          <svg viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        </div>
        <div class="stat-info">
          <p>Total Active</p>
          <h2><%= totalUsers %></h2>
        </div>
      </div>
    </div>

    <!-- Table Card -->
    <div class="table-card">
      <div class="table-topbar">
        <div class="table-topbar-left">
          <h3>Banned Accounts</h3>
          <p>Users who have been restricted from the platform</p>
        </div>
        <div class="search-box">
          <svg viewBox="0 0 24 24" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <input id="searchInput" placeholder="Search banned users..." />
        </div>
      </div>

      <% if (bannedList.length === 0) { %>
        <!-- Empty State -->
        <div class="empty-state">
          <div class="empty-icon">
            <svg viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          </div>
          <h3>No banned users</h3>
          <p>All users are currently in good standing on the platform.</p>
        </div>

      <% } else { %>
        <table id="bannedTable">
          <thead>
            <tr>
              <th>User</th>
              <th>Role</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <%
              const avatarColors = [
                { bg:'#fff0f0', tc:'#dc2626' },
                { bg:'#fce7f3', tc:'#be185d' },
                { bg:'#fff3e0', tc:'#c2410c' },
                { bg:'#fef9c3', tc:'#92400e' },
                { bg:'#f0ebff', tc:'#6c63ff' },
                { bg:'#e0f2fe', tc:'#0369a1' }
              ];
            %>
            <% bannedList.forEach((user, i) => {
              const col = avatarColors[i % avatarColors.length];
              const initials = (user.name || 'U').split(' ').map(x => x[0]).join('').toUpperCase().slice(0,2);
            %>
              <tr data-name="<%= (user.name || '').toLowerCase() %>"
                  data-email="<%= (user.email || '').toLowerCase() %>">

                <td>
                  <div class="user-cell">
                    <div class="u-avatar" style="background:<%= col.bg %>;color:<%= col.tc %>">
                      <%= initials %>
                    </div>
                    <div>
                      <div class="u-name"><%= user.name || 'Unknown' %></div>
                      <div class="u-email"><%= user.email %></div>
                    </div>
                  </div>
                </td>

                <td>
                  <span class="role-badge <%= user.role === 'admin' ? 'admin' : '' %>">
                    <%= user.role || 'user' %>
                  </span>
                </td>

                <td>
                  <span class="banned-badge">
                    <span class="banned-dot"></span>
                    Banned
                  </span>
                </td>

                <td>
                  <div class="action-btns">
                    <form method="POST" action="/admin/unban/<%= user._id %>" style="display:inline">
                      <button type="submit" class="act-btn unban">✓ Unban</button>
                    </form>
                    <a href="/admin/users/<%= user._id %>" class="act-btn view">👁 View</a>
                  </div>
                </td>

              </tr>
            <% }) %>
          </tbody>
        </table>

        <div class="table-footer">
          <span class="page-info" id="pageInfo">Showing <%= bannedList.length %> banned user(s)</span>
        </div>
      <% } %>

    </div>

  </div><!-- /.main -->

  <script>
    /* ── Live Search ── */
    document.getElementById('searchInput').addEventListener('input', function() {
      const term = this.value.toLowerCase();
      const rows = document.querySelectorAll('#bannedTable tbody tr');
      let visible = 0;

      rows.forEach(row => {
        const name  = row.dataset.name  || '';
        const email = row.dataset.email || '';
        const show  = name.includes(term) || email.includes(term);
        row.style.display = show ? '' : 'none';
        if (show) visible++;
      });

      const info = document.getElementById('pageInfo');
      if (info) info.textContent = `Showing ${visible} banned user(s)`;
    });
  </script>
</body>
</html>
